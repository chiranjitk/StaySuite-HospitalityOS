/// WorkOrder - Maintenance work orders assigned to vendors
model WorkOrder {
  id               String        @id @default(uuid_generate_v4()) @db.Uuid
  tenantId         String
  propertyId       String
  vendorId         String?
  roomId           String?
  assetId          String?
  workOrderNumber  String        @unique
  title            String
  description      String?
  type             String        @default("general") // general, plumbing, electrical, hvac, carpentry, painting, cleaning, other
  priority         String        @default("medium") // low, medium, high, urgent
  status           String        @default("pending") // pending, assigned, in_progress, completed, cancelled, on_hold
  requestedBy      String?
  assignedAt       DateTime @db.TimestampTz?
  scheduledDate    DateTime @db.TimestampTz?
  startedAt        DateTime @db.TimestampTz?
  completedAt      DateTime @db.TimestampTz?
  estimatedCost    Float?
  actualCost       Float?
  estimatedHours   Float?
  actualHours      Float?
  notes            String?
  completionNotes  String?
  attachments      String        @default("[]") // JSON array of attachment URLs
  vendorNotes      String?       // Notes from vendor
  rating           Int?          // Guest/staff rating 1-5
  feedback         String?       // Feedback on work quality
  createdAt        DateTime @db.TimestampTz      @default(now())
  updatedAt        DateTime @db.TimestampTz      @updatedAt
  deletedAt        DateTime @db.TimestampTz?
  vendor           Vendor?       @relation(fields: [vendorId], references: [id])
  room             Room?         @relation(fields: [roomId], references: [id])
  property         Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payments         VendorPayment[]
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([vendorId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([scheduledDate])
}

/// VendorPayment - Payments to vendors for work orders
model VendorPayment {
  id              String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId        String
  vendorId        String
  workOrderId     String?
  paymentNumber   String    @unique
  amount          Float
  currency        String    @default("USD")
  status          String    @default("pending") // pending, processing, paid, failed, cancelled
  paymentMethod   String    @default("bank_transfer") // bank_transfer, check, cash, other
  paymentDate     DateTime @db.TimestampTz?
  dueDate         DateTime @db.TimestampTz?
  bankName        String?
  bankAccount     String?
  checkNumber     String?
  transactionRef  String?
  notes           String?
  paidAt          DateTime @db.TimestampTz?
  cancelledAt     DateTime @db.TimestampTz?
  cancelReason    String?
  createdAt       DateTime @db.TimestampTz  @default(now())
  updatedAt       DateTime @db.TimestampTz  @updatedAt
  vendor          Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder? @relation(fields: [workOrderId], references: [id], onDelete: SetNull)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([vendorId])
  @@index([workOrderId])
  @@index([status])
  @@index([dueDate])
}

