/// ChannelDeadLetterQueue - Failed channel operations that exceeded max retry attempts
/// Multi-tenant: scoped by tenantId
model ChannelDeadLetterQueue {
  id                 String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId           String
  propertyId         String?
  syncLogId          String?
  channelCode        String
  operation          String
  payload            String    @default("{}")
  error              String
  attemptCount       Int       @default(0)
  originalCreatedAt  DateTime @db.TimestampTz
  createdAt          DateTime @db.TimestampTz  @default(now())
  updatedAt          DateTime @db.TimestampTz  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([channelCode])
  @@index([createdAt])
}

/// ExternalReview - Reviews from external platforms (Booking.com, Google, TripAdvisor, etc.)
/// Multi-tenant: scoped by tenantId, optionally linked to propertyId
model ExternalReview {
  id                String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId          String
  propertyId        String?
  source            String    @default("unknown")
  externalId        String?
  content           String
  rating            Int
  reviewerName      String?
  reviewDate        DateTime @db.TimestampTz  @default(now())
  sentimentScore    Float?
  sentimentLabel    String?
  sentimentAspects  String?
  sentimentKeywords String?
  responseText      String?
  respondedAt       DateTime @db.TimestampTz?
  createdAt         DateTime @db.TimestampTz  @default(now())
  updatedAt         DateTime @db.TimestampTz  @updatedAt
  property          Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([source])
  @@index([reviewDate])
}
