/// Notification - In-app notifications for users
model Notification {
  id           String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId     String
  userId       String
  type         String    // booking, payment, housekeeping, maintenance, system, etc.
  category     String    // info, warning, success, error
  title        String
  message      String
  data         String    @default("{}") // JSON: Additional context data
  link         String?   // URL to navigate when clicked
  icon         String?   // Icon name or URL
  image        String?   // Optional image URL
  priority     String    @default("normal") // low, normal, high, urgent
  readAt       DateTime @db.TimestampTz?
  dismissedAt  DateTime @db.TimestampTz?
