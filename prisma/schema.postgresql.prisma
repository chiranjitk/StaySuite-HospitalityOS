  id                   String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId             String
  propertyId           String
  name                 String
  description          String?
  ipAddress            String
  macAddress           String?
  vendor               String
  model                String?
  version              String?
  radiusSecret         String
  radiusAuthPort       Int       @default(1812)
  radiusAcctPort       Int       @default(1813)
