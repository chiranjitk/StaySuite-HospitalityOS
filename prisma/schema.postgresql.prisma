  tenantId        String
  propertyId      String?
  syncLogId       String?
  channelCode     String
  operation       String
  payload         String    @default("{}")
  attemptCount    Int       @default(0)
  nextRetryAt     DateTime @db.TimestampTz
  status          String    @default("pending")
