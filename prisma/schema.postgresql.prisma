  benefits         String   @default("[]") // JSON array of benefit strings
  color            String   @default("#cd7f32") // tier color for UI
  icon             String?  // optional icon name
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @db.TimestampTz @default(now())
  updatedAt        DateTime @db.TimestampTz @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([minPoints])
}

/// LoyaltyReward - Rewards available for point redemption
model LoyaltyReward {
  id                 String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId           String
  name               String
  description        String?
  category           String   @default("general") // general, room, dining, spa, experience
