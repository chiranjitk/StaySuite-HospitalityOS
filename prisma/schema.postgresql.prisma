  messagesMonth       Int      @default(0)
  emailsSent          Int      @default(0)
  emailsMonth         Int      @default(0)
  smsSent             Int      @default(0)
  smsMonth            Int      @default(0)
  storageUsedMb       Float    @default(0)
  storageFiles        Int      @default(0)
  webhooksSent        Int      @default(0)
  webhooksMonth       Int      @default(0)
