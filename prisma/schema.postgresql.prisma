/// RadiusNAS - FreeRADIUS NAS clients (routers, access points)
/// Maps to FreeRADIUS clients.conf / nas table in SQL module
model RadiusNAS {
  id              String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId        String
  propertyId      String
  name            String
  shortname       String
  ipAddress       String
  type            String    @default("other") // cisco, mikrotik, aruba, tplink, other
  ports           String?   // RADIUS ports
  secret          String    // Shared secret
  community       String?   // SNMP community
  description     String?
  coaEnabled      Boolean   @default(true)
  coaPort         Int       @default(3799)
  authPort        Int       @default(1812)
  acctPort        Int       @default(1813)
  status          String    @default("active")
  lastSeenAt      DateTime @db.TimestampTz?
  totalAuths      Int       @default(0)
  totalAccts      Int       @default(0)
