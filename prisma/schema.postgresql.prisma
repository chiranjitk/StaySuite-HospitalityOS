  groupname String
  attribute String
  op        String   @default(":=")
  value     String
  priority  Int      @default(0)
  createdAt DateTime @db.TimestampTz @default(now())

  @@index([groupname])
}

/// RadGroupReply - Group-level reply attributes
model RadGroupReply {
  id        String   @id @default(uuid_generate_v4()) @db.Uuid
  groupname String
  attribute String
  op        String   @default(":=")
  value     String
  priority  Int      @default(0)
  createdAt DateTime @db.TimestampTz @default(now())

