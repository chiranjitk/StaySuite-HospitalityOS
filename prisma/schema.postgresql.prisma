generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// SaaS Tenant - Each hotel/hotel chain is a tenant
model Tenant {
  id                    String                 @id @default(uuid_generate_v4()) @db.Uuid
  name                  String
  slug                  String                 @unique
  logo                  String?
  email                 String @db.Citext
  phone                 String?
  address               String?
  city                  String?
  country               String?
  timezone              String                 @default("UTC")
  currency              String                 @default("USD")
  language              String                 @default("en")
  plan                  String                 @default("trial")
  status                String                 @default("trial")
  trialEndsAt           DateTime @db.TimestampTz?
  subscriptionStartsAt  DateTime @db.TimestampTz?
  subscriptionEndsAt    DateTime @db.TimestampTz?
  maxProperties         Int                    @default(1)
  maxUsers              Int                    @default(5)
  maxRooms              Int                    @default(50)
  storageLimitMb        Int                    @default(500)
  features              String                 @default("{}")
  settings              String                 @default("{}")
  createdAt             DateTime @db.TimestampTz               @default(now())
  updatedAt             DateTime @db.TimestampTz               @updatedAt
  deletedAt             DateTime @db.TimestampTz?
  aiSuggestions         AISuggestion[]
  auditLogs             AuditLog[]
  automationRules       AutomationRule[]
  brands                Brand[]
  cameraEvents          CameraEvent[]
  campaigns             Campaign[]
  communicationChannels CommunicationChannel[]
  competitorPrices      CompetitorPrice[]
  demandForecasts       DemandForecast[]
  energyMetrics         EnergyMetric[]
  guests                Guest[]
  guestBehaviors        GuestBehavior[]
  guestJourneyEvents    GuestJourney[]
  guestRecommendations  GuestRecommendation[]
  segments              GuestSegment[]
  integrations          Integration[]
  inventoryLocks        InventoryLock[]
  iotDevices            IoTDevice[]
  messageTemplates      MessageTemplate[]
  notifications         NotificationTemplate[]
  parkingSlots          ParkingSlot[]
  pricingRules          PricingRule[]
  properties            Property[]
  purchaseOrders        PurchaseOrder[]
  roles                 Role[]
  securityIncidents     SecurityIncident[]
  shiftTemplates        ShiftTemplate[]
  staffLeaves           StaffLeave[]
  staffPerformances     StaffPerformance[]
  staffSchedules        StaffSchedule[]
  stockItems            StockItem[]
  users                 User[]
  vehicles              Vehicle[]
  vendors               Vendor[]
  workOrders            WorkOrder[]
  vendorPayments        VendorPayment[]
  webhooks              WebhookEndpoint[]
  wifiAAAConfigs        WiFiAAAConfig[]
  wifiGateways          WiFiGateway[]
  wifiPlans             WiFiPlan[]
  wifiSessions          WiFiSession[]
  wifiUsers             WiFiUser[]
  vouchers              WiFiVoucher[]
  radiusNAS             RadiusNAS[]
  radiusServerConfigs   RadiusServerConfig[]
  amenities             Amenity[]
  adCampaigns           AdCampaign[]
  googleHotelAdsConnections GoogleHotelAdsConnection[]
  metasearchConnections MetasearchConnection[]
  loyaltyTiers         LoyaltyTier[]
  loyaltyRewards       LoyaltyReward[]
  loyaltyRedemptions   LoyaltyRedemption[]
  loyaltyTransactions  LoyaltyPointTransaction[]
  userNotifications    Notification[]
  scheduledNotifications ScheduledNotification[]
  userFcmTokens        UserFcmToken[]
  staffSkills          StaffSkill[]
  taskAssignmentSuggestions TaskAssignmentSuggestion[]
  staffWorkloads       StaffWorkload[]
  assets               Asset[]
  preventiveMaintenances PreventiveMaintenance[]
  bankAccounts         BankAccount[]
  bankTransactions     BankTransaction[]
  reconciliations      Reconciliation[]
  taxReports           TaxReport[]
  staffChannels        StaffChannel[]
  gdprRequests         GDPRRequest[]
  consentRecords       ConsentRecord[]
  ssoConnections       SSOConnection[]
  usageLogs            UsageLog[]
  usageSummary         UsageSummary?
  discounts            Discount[]
  ratePlans            RatePlan[]
  cancellationPolicies CancellationPolicy[]
  inspectionTemplates  InspectionTemplate[]
  securitySettings     SecuritySettings[]
  securityEvents       SecurityEvent[]
  channelRetryQueues   ChannelRetryQueue[]
  channelDeadLetterQueues ChannelDeadLetterQueue[]
  externalReviews      ExternalReview[]
}

/// SecuritySettings - Per-tenant security configuration
/// Controls session limits, password policies, and idle timeouts
model SecuritySettings {
  id                    String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId              String
  maxConcurrentSessions Int      @default(3)
  sessionTimeoutMinutes Int      @default(30)
  passwordExpiryDays    Int      @default(90)
  minPasswordLength     Int      @default(8)
  requireUppercase      Boolean  @default(false)
  requireLowercase      Boolean  @default(false)
  requireNumbers        Boolean  @default(false)
  requireSpecialChars   Boolean  @default(false)
  enable2FA             Boolean  @default(false)
  createdAt             DateTime @db.TimestampTz @default(now())
  updatedAt             DateTime @db.TimestampTz @updatedAt
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId])
  @@index([tenantId])
}

model User {
  id               String             @id @default(uuid_generate_v4()) @db.Uuid
  tenantId         String
  email            String @db.Citext
  passwordHash     String
  isVerified       Boolean            @default(false)
  verifiedAt       DateTime @db.TimestampTz?
  firstName        String
  lastName         String
  avatar           String?
  phone            String?
  jobTitle         String?
  department       String?
  roleId           String?
  lastLoginAt      DateTime @db.TimestampTz?
  lastLoginIp      String?
  passwordChangedAt DateTime @db.TimestampTz?   // Track when password was last changed for expiry enforcement
  failedAttempts   Int                @default(0)
  lockedUntil      DateTime @db.TimestampTz?
  twoFactorEnabled Boolean            @default(false)
  twoFactorSecret  String?
  backupCodes      String?   // Comma-separated hashed backup codes
  preferences      String             @default("{}") // JSON: { emailNotifications, pushNotifications, smsNotifications, marketingEmails, darkMode, compactMode, language, timezone, dateFormat }
  isPlatformAdmin  Boolean            @default(false) // Platform-level admin can manage all tenants
  status           String             @default("active")
  invitedAt        DateTime @db.TimestampTz?
  invitedBy        String?
  createdAt        DateTime @db.TimestampTz           @default(now())
  updatedAt        DateTime @db.TimestampTz           @updatedAt
  deletedAt        DateTime @db.TimestampTz?
  auditLogs        AuditLog[]
  chatMessages     ChatMessage[]
  serviceRequests  ServiceRequest[]
  sessions         Session[]
  attendance       StaffAttendance[]
  leaves           StaffLeave[]
  performances     StaffPerformance[]
  schedules        StaffSchedule[]
  shifts           StaffShift[]
  tasks            Task[]
  createdTasks       Task[]    @relation("TaskCreator")
  notifications    Notification[]
  notificationPreferences NotificationPreference[]
  fcmTokens        UserFcmToken[]
  staffSkills      StaffSkill[]
  channelMemberships StaffChannelMember[]
  sentStaffMessages StaffChatMessage[]
  ssoSessions       SSOSession[]
  role             Role?              @relation(fields: [roleId], references: [id])
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
}

model Session {
  id           String   @id @default(uuid_generate_v4()) @db.Uuid
  userId       String
  token        String   @unique
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime @db.TimestampTz
  lastActive   DateTime @db.TimestampTz? // Track last activity for idle timeout
  createdAt    DateTime @db.TimestampTz @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Role {
  id          String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId    String
  name        String
  displayName String
  description String?
  permissions String   @default("[]")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @db.TimestampTz @default(now())
  updatedAt   DateTime @db.TimestampTz @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model AuditLog {
  id            String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId      String
  userId        String?
  module        String
  action        String
  entityType    String
  entityId      String?
  oldValue      String?
  newValue      String?
  ipAddress     String?
  userAgent     String?
  correlationId String?
  createdAt     DateTime @db.TimestampTz @default(now())
  user          User?    @relation(fields: [userId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
}

model Brand {
  id             String     @id @default(uuid_generate_v4()) @db.Uuid
  tenantId       String
  name           String
  code           String     @unique
  description    String?
  logo           String?
  primaryColor   String?
  secondaryColor String?
  standards      String     @default("{}")
  status         String     @default("active")
  createdAt      DateTime @db.TimestampTz   @default(now())
  updatedAt      DateTime @db.TimestampTz   @updatedAt
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  properties     Property[]

  @@index([tenantId])
}

model Property {
  id               String            @id @default(uuid_generate_v4()) @db.Uuid
  tenantId         String
  name             String
  slug             String
  description      String?
  type             String            @default("hotel")
  address          String
  city             String
  state            String?
  country          String
  postalCode       String?
  latitude         Float?
  longitude        Float?
  email            String?
  phone            String?
  website          String?
  logo             String?
  primaryColor     String?
  secondaryColor   String?
  checkInTime      String            @default("14:00")
  checkOutTime     String            @default("11:00")
  timezone         String            @default("UTC")
  currency         String            @default("USD")
  taxId            String?           // GST/Tax registration number
  taxType          String            @default("gst") // gst, vat, sales_tax, none
  defaultTaxRate   Float             @default(0)
  taxComponents    String            @default("[]") // JSON: [{name, rate, type}]
  serviceChargePercent Float         @default(0)
  includeTaxInPrice Boolean          @default(false)
  totalRooms       Int               @default(0)
  totalFloors      Int               @default(0)
  noShowSettings   String            @default("{\"noShowBufferHours\":1,\"autoProcessNoShows\":false,\"noShowNotificationEnabled\":true}")
  status           String            @default("active")
  createdAt        DateTime @db.TimestampTz          @default(now())
  updatedAt        DateTime @db.TimestampTz          @updatedAt
  deletedAt        DateTime @db.TimestampTz?
  brandId          String?
  cameras          Camera[]
  cameraGroups     CameraGroup[]
  competitorPrices CompetitorPrice[]
  demandForecasts  DemandForecast[]
  energyMetrics    EnergyMetric[]
  events           Event[]
  eventSpaces      EventSpace[]
  floorPlans       FloorPlan[]
  inventoryLocks   InventoryLock[]
  iotDevices       IoTDevice[]
  menuItems        MenuItem[]
  orders           Order[]
  orderCategories  OrderCategory[]
  pricingRules     PricingRule[]
  brand            Brand?            @relation(fields: [brandId], references: [id])
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables           RestaurantTable[]
  rooms            Room[]
  roomTypes        RoomType[]
  wifiAAAConfig    WiFiAAAConfig?
  wifiGateways     WiFiGateway[]
  wifiUsers        WiFiUser[]
  radiusNAS        RadiusNAS[]
  radiusServerConfig RadiusServerConfig?
  assets                  Asset[]
  preventiveMaintenances  PreventiveMaintenance[]
  workOrders              WorkOrder[]
  bookings                Booking[]
  guestReviews            GuestReview[]
  externalReviews        ExternalReview[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([brandId])
}

model RoomType {
  id                    String               @id @default(uuid_generate_v4()) @db.Uuid
  propertyId            String
  name                  String
  code                  String
  description           String?
  maxAdults             Int                  @default(2)
  maxChildren           Int                  @default(0)
  maxOccupancy          Int                  @default(2)
  sizeSqMeters          Float?
  sizeSqFeet            Float?
  amenities             String               @default("[]")
  basePrice             Float
  currency              String               @default("USD")
  images                String               @default("[]")
  sortOrder             Int                  @default(0)
  totalRooms            Int                  @default(0)
  overbookingEnabled    Boolean              @default(false)
  overbookingPercentage Float                @default(0)
  overbookingLimit      Int                  @default(0)
  status                String               @default("active")
  createdAt             DateTime @db.TimestampTz             @default(now())
  updatedAt             DateTime @db.TimestampTz             @updatedAt
  deletedAt             DateTime @db.TimestampTz?
  bookings              Booking[]
  channelMappings       ChannelMapping[]
  channelRestrictions   ChannelRestriction[]
  competitorPrices      CompetitorPrice[]
  demandForecasts       DemandForecast[]
  inventoryLocks        InventoryLock[]
  ratePlans             RatePlan[]
  rooms                 Room[]
  property              Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, code])
  @@index([propertyId])
}

model Room {
  id                String          @id @default(uuid_generate_v4()) @db.Uuid
  propertyId        String
  roomTypeId        String
  number            String
  name              String?
  floor             Int             @default(1)
  isAccessible      Boolean         @default(false)
  isSmoking         Boolean         @default(false)
  hasBalcony        Boolean         @default(false)
  hasSeaView        Boolean         @default(false)
  hasMountainView   Boolean         @default(false)
  status            String          @default("available")
  smartRoomConfig   String?
  digitalKeyEnabled Boolean         @default(true)
  digitalKeySecret  String?
  housekeepingStatus  String    @default("clean") // clean, dirty, cleaning, inspected
  lastCleanedAt       DateTime @db.TimestampTz?
  lastInspectedAt     DateTime @db.TimestampTz?
  inspectedBy         String?
  hkPriority          String    @default("normal") // normal, high, vip, urgent
  hkNotes             String?   // Special cleaning instructions
  dnd                 Boolean   @default(false) // Do Not Disturb
  currentTaskId       String?   @unique
  images            String          @default("[]")
  createdAt         DateTime @db.TimestampTz        @default(now())
  updatedAt         DateTime @db.TimestampTz        @updatedAt
  deletedAt         DateTime @db.TimestampTz?
  bookings          Booking[]
  inventoryLocks    InventoryLock[]
  iotDevices        IoTDevice[]
  floorPlanRooms    FloorPlanRoom[]
  roomType          RoomType        @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  property          Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tasks             Task[]
  assets            Asset[]
  workOrders        WorkOrder[]
  currentTask       Task?           @relation("RoomCurrentTask", fields: [currentTaskId], references: [id])

  @@unique([propertyId, number])
  @@index([propertyId])
  @@index([roomTypeId])
  @@index([status])
  @@index([housekeepingStatus])
  @@index([propertyId, status])
  @@index([currentTaskId])
}

model FloorPlan {
  id            String          @id @default(uuid_generate_v4()) @db.Uuid
  propertyId    String
  floor         Int
  name          String
  imageUrl      String?
  svgData       String?
  roomPositions String          @default("[]") // JSON array of room positions: [{roomId, x, y, width, height}]
  width         Int             @default(800)
  height        Int             @default(600)
  gridSize      Int             @default(20) // Grid cell size in pixels
  createdAt     DateTime @db.TimestampTz        @default(now())
  updatedAt     DateTime @db.TimestampTz        @updatedAt
  property      Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  floorPlanRooms FloorPlanRoom[]

  @@unique([propertyId, floor])
}

model FloorPlanRoom {
  id          String   @id @default(uuid_generate_v4()) @db.Uuid
  floorPlanId String
  roomId      String
  x           Int
  y           Int
  width       Int      @default(80)
  height      Int      @default(60)
  rotation    Int      @default(0)
  createdAt   DateTime @db.TimestampTz @default(now())
  updatedAt   DateTime @db.TimestampTz @updatedAt
  floorPlan   FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([floorPlanId, roomId])
  @@index([floorPlanId])
  @@index([roomId])
}

model RatePlan {
  id                 String           @id @default(uuid_generate_v4()) @db.Uuid
  tenantId           String
  roomTypeId         String
  name               String
  code               String
  description        String?
  basePrice          Float
  currency           String           @default("USD")
  mealPlan           String           @default("room_only")
  minStay            Int              @default(1)
  maxStay            Int?
  advanceBookingDays Int?
  cancellationPolicy String?
  cancellationHours  Int?
  bookingStartDays   Int?
  bookingEndDays     Int?
  promoCode          String?
  discountPercent    Float?
  discountAmount     Float?
  promoStart         DateTime @db.TimestampTz?
  promoEnd           DateTime @db.TimestampTz?
  status             String           @default("active")
  createdAt          DateTime @db.TimestampTz         @default(now())
  updatedAt          DateTime @db.TimestampTz         @updatedAt
  deletedAt          DateTime @db.TimestampTz?
  channelMappings    ChannelMapping[]
  priceOverrides     PriceOverride[]
  roomType           RoomType         @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookings           Booking[]

  @@unique([tenantId, roomTypeId, code])
  @@index([tenantId])
  @@index([roomTypeId])
}

/// CancellationPolicy - Configurable cancellation rules per property/rate plan
/// Multi-tenant: scoped by tenantId, optionally linked to propertyId or ratePlanId
model CancellationPolicy {
  id                     String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId               String
  propertyId             String?
  ratePlanId             String?
  name                   String
  description            String?
  freeCancelHoursBefore  Int       @default(48)
  penaltyPercent         Float     @default(50)
  noShowPenaltyPercent   Float     @default(100)
  penaltyType            String    @default("percentage") // percentage, fixed_nights, first_night
  penaltyFixedAmount     Float?
  penaltyNights          Int?
  exceptions             String    @default("[]") // JSON: [{type: "loyalty_tier", value: "gold"}, {type: "segment", value: "corporate"}]
  isActive               Boolean   @default(true)
  sortOrder              Int       @default(0)
  createdAt              DateTime @db.TimestampTz  @default(now())
  updatedAt              DateTime @db.TimestampTz  @updatedAt
  tenant                 Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([ratePlanId])
  @@index([isActive])
}

/// InspectionTemplate - Reusable checklist templates for room inspections
/// Multi-tenant: scoped by tenantId, optionally per property or room type
model InspectionTemplate {
  id          String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId    String
  propertyId  String?
  name        String
  description String?
  roomType    String?   // null = all room types; "standard", "suite", "vip", "deluxe", "deep_clean", "public_area"
  category    String    @default("room") // room, public_area, kitchen, amenity
  items       String    @default("[]") // JSON: [{id, name, category, required, sortOrder}]
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime @db.TimestampTz  @default(now())
  updatedAt   DateTime @db.TimestampTz  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  inspectionResults InspectionResult[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomType])
  @@index([isActive])
}

/// InspectionResult - Completed inspection records with scores and evidence
/// Multi-tenant: scoped by tenantId, linked to property/room/task
model InspectionResult {
  id          String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId    String
  propertyId  String
  roomId      String
  taskId      String?   // Link to the housekeeping task that triggered inspection
  templateId  String
  inspectorId String
  score       Int?      // 0-100 quality score
  passed      Boolean   @default(false)
  items       String    @default("[]") // JSON: [{templateItemId, name, passed, notes, photoUrl}]
  notes       String?
  completedAt DateTime @db.TimestampTz?
  reAssigned  Boolean   @default(false) // Were failed items sent back for re-cleaning?
  createdAt   DateTime @db.TimestampTz  @default(now())
  updatedAt   DateTime @db.TimestampTz  @updatedAt

  template    InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([taskId])
  @@index([templateId])
  @@index([inspectorId])
  @@index([completedAt])
}

model PriceOverride {
  id                String   @id @default(uuid_generate_v4()) @db.Uuid
  ratePlanId        String
  date              DateTime @db.TimestampTz
  price             Float
  reason            String?
  minStay           Int?
  closedToArrival   Boolean  @default(false)
  closedToDeparture Boolean  @default(false)
  createdAt         DateTime @db.TimestampTz @default(now())
  updatedAt         DateTime @db.TimestampTz @updatedAt
  ratePlan          RatePlan @relation(fields: [ratePlanId], references: [id], onDelete: Cascade)

  @@unique([ratePlanId, date])
}

model InventoryLock {
  id         String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId   String
  propertyId String
  roomId     String?
  roomTypeId String?
  startDate  DateTime @db.TimestampTz
  endDate    DateTime @db.TimestampTz
  reason     String
  lockType   String    @default("maintenance")
  sessionId  String?
  expiresAt  DateTime @db.TimestampTz?
  createdBy  String?
  createdAt  DateTime @db.TimestampTz  @default(now())
  updatedAt  DateTime @db.TimestampTz  @updatedAt
  roomType   RoomType? @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  room       Room?     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([roomTypeId])
  @@index([sessionId])
  @@index([expiresAt])
}

model Guest {
  id                  String                @id @default(uuid_generate_v4()) @db.Uuid
  tenantId            String
  firstName           String
  lastName            String
  email               String? @db.Citext
  phone               String?
  alternatePhone      String?
  nationality         String?
  dateOfBirth         DateTime @db.TimestampTz?
  gender              String?
  idType              String?
  idNumber            String?
  idExpiry            DateTime @db.TimestampTz?
  idCountry           String?
  address             String?
  city                String?
  state               String?
  country             String?
  postalCode          String?
  preferences         String                @default("{}")
  dietaryRequirements String?
  specialRequests     String?
  avatar              String?
  notes               String?
  tags                String                @default("[]")
  loyaltyTier         String                @default("bronze")
  loyaltyPoints       Int                   @default(0)
  totalStays          Int                   @default(0)
  totalSpent          Float                 @default(0)
  isVip               Boolean               @default(false)
  vipLevel            String?
  source              String                @default("direct")
  sourceId            String?
  emailOptIn          Boolean               @default(false)
  smsOptIn            Boolean               @default(false)
  kycStatus           String                @default("pending")
  kycVerifiedAt       DateTime @db.TimestampTz?
  createdAt           DateTime @db.TimestampTz              @default(now())
  updatedAt           DateTime @db.TimestampTz              @updatedAt
  deletedAt           DateTime @db.TimestampTz?
  bookings            Booking[]
  tenant              Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  behavior            GuestBehavior?
  documents           GuestDocument[]
  feedback            GuestFeedback[]
  journeyEvents       GuestJourney[]
  recommendations     GuestRecommendation[]
  reviews             GuestReview[]
  stays               GuestStay[]
  payments            Payment[]
  segmentMemberships  SegmentMembership[]
  vehicles            Vehicle[]
  loyaltyRedemptions  LoyaltyRedemption[]
  loyaltyTransactions LoyaltyPointTransaction[]

  @@index([tenantId])
  @@index([email])
  @@index([tenantId, email])
  @@index([phone])
}

model GuestDocument {
  id              String    @id @default(uuid_generate_v4()) @db.Uuid
  guestId         String
  type            String
  name            String
  fileUrl         String
  status          String    @default("pending")
  verifiedAt      DateTime @db.TimestampTz?
  verifiedBy      String?
  rejectionReason String?
  expiryDate      DateTime @db.TimestampTz?
  createdAt       DateTime @db.TimestampTz  @default(now())
  updatedAt       DateTime @db.TimestampTz  @updatedAt
