  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([rewardId])
  @@index([status])
  @@index([redemptionCode])
}

/// LoyaltyPointTransaction - Track all point movements
model LoyaltyPointTransaction {
  id             String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId       String
  guestId        String
  points         Int      // positive for earn, negative for redeem
  balance        Int      // balance after transaction
  type           String   // earn, redeem, expire, adjust, bonus, referral
  source         String?  // booking, promotion, manual, etc.
  referenceId    String?  // related entity id (booking, redemption, etc.)
  referenceType  String?  // booking, redemption, etc.
  description    String?
  expiresAt      DateTime @db.TimestampTz? // for points that expire
  createdAt      DateTime @db.TimestampTz @default(now())
  guest          Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([type])
  @@index([expiresAt])
}

/// BankAccount - Hotel bank accounts for reconciliation
model BankAccount {
  id                 String            @id @default(uuid_generate_v4()) @db.Uuid
  tenantId           String
  propertyId         String?
  accountName        String
  accountNumber      String            // Masked or encrypted
  bankName           String
  bankCode           String?           // IFSC, SWIFT, Routing number, etc.
  accountType        String            @default("checking") // checking, savings, money_market
  currency           String            @default("USD")
  openingBalance     Float             @default(0)
  currentBalance     Float             @default(0)
  lastReconciledAt   DateTime @db.TimestampTz?
  lastStatementDate  DateTime @db.TimestampTz?
  status             String            @default("active") // active, closed, frozen
  isDefault          Boolean           @default(false)
  notes              String?
  createdAt          DateTime @db.TimestampTz          @default(now())
  updatedAt          DateTime @db.TimestampTz          @updatedAt
  deletedAt          DateTime @db.TimestampTz?
  transactions       BankTransaction[]
  reconciliations    Reconciliation[]
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankName])
  @@index([status])
}

/// BankTransaction - Transactions from bank statements
model BankTransaction {
  id                String            @id @default(uuid_generate_v4()) @db.Uuid
  tenantId          String
  bankAccountId     String
  transactionDate   DateTime @db.TimestampTz
  valueDate         DateTime @db.TimestampTz?         // Value date (may differ from transaction date)
  transactionType   String            // debit, credit
  amount            Float
  currency          String            @default("USD")
  balance           Float?            // Balance after transaction
  description       String?
  reference         String?           // Bank reference number
  chequeNumber      String?
  payeeName         String?
  payeeAccount      String?
  category          String?           // User-defined category
  subCategory       String?
  isReconciled      Boolean           @default(false)
  reconciledAt      DateTime @db.TimestampTz?
  importSource      String            @default("manual") // manual, csv, api, ofx
  importBatchId     String?           // Batch ID for bulk imports
  rawLine           String?           // Original line from import
  notes             String?
  createdAt         DateTime @db.TimestampTz          @default(now())
  updatedAt         DateTime @db.TimestampTz          @updatedAt
  deletedAt         DateTime @db.TimestampTz?
  bankAccount       BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliations   Reconciliation[]
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isReconciled])
  @@index([transactionType])
  @@index([importBatchId])
}

/// Reconciliation - Matching bank transactions to payments
model Reconciliation {
  id                    String          @id @default(uuid_generate_v4()) @db.Uuid
  tenantId              String
  bankAccountId         String
  bankTransactionId     String
  paymentId             String?         // Matched payment from PMS
  folioId               String?         // Matched folio
  matchType             String          @default("manual") // auto, manual, partial
  matchConfidence       Float?          // Confidence score for auto-matching (0-1)
  matchCriteria         String          @default("{}") // JSON: matched fields
  status                String          @default("matched") // matched, unmatched, disputed, adjusted
  reconciledAmount      Float           // Amount reconciled (may differ from transaction)
  adjustmentAmount      Float           @default(0) // Difference if any
  adjustmentReason      String?
  reconciledBy          String?         // User who performed reconciliation
  reconciledAt          DateTime @db.TimestampTz        @default(now())
  notes                 String?
  createdAt             DateTime @db.TimestampTz        @default(now())
  updatedAt             DateTime @db.TimestampTz        @updatedAt
  bankAccount           BankAccount     @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  bankTransaction       BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([bankTransactionId])
  @@index([paymentId])
  @@index([status])
  @@index([reconciledAt])
}

/// TaxReport - Tax reports for different jurisdictions
model TaxReport {
  id                  String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId            String
  propertyId          String?
  reportNumber        String    @unique
  reportType          String    // gst, vat, sales_tax, occupancy_tax, service_tax
  jurisdiction        String    @default("india") // india, us, eu, uk, canada, australia, etc.
  periodStart         DateTime @db.TimestampTz
  periodEnd           DateTime @db.TimestampTz
  filingDueDate       DateTime @db.TimestampTz?
  grossRevenue        Float     @default(0)
  taxableRevenue      Float     @default(0)
  taxCollected        Float     @default(0)
  taxPaid             Float     @default(0)
  taxDue              Float     @default(0)
  taxRefundable       Float     @default(0)
  adjustments         Float     @default(0)
  adjustmentReason    String?
  // For Indian GST
  cgstAmount          Float     @default(0) // Central GST
  sgstAmount          Float     @default(0) // State GST
  igstAmount          Float     @default(0) // Integrated GST
  cessAmount          Float     @default(0) // Cess
  // For US Sales Tax
  stateTaxAmount      Float     @default(0)
  localTaxAmount      Float     @default(0)
  // For VAT
  vatOutput          Float     @default(0) // VAT collected
  vatInput           Float     @default(0) // VAT paid (input credit)
  // Reporting details
  transactionCount    Int       @default(0)
  exemptTransactions  Int       @default(0)
  exportTransactions  Int       @default(0)
  // Status and filing
  status              String    @default("draft") // draft, submitted, filed, paid, audited
  filedAt             DateTime @db.TimestampTz?
  filedBy             String?
  filingReference     String?   // Government acknowledgment number
  paymentReference    String?
  paidAt              DateTime @db.TimestampTz?
  // Attachments and notes
  attachmentUrl       String?
  notes               String?
  internalNotes       String?
  // Audit trail
  createdAt           DateTime @db.TimestampTz  @default(now())
  updatedAt           DateTime @db.TimestampTz  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([reportType])
  @@index([jurisdiction])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([filingDueDate])
}


/// Staff Communication Channel - Internal team channels for staff communication
model StaffChannel {
  id            String             @id @default(uuid_generate_v4()) @db.Uuid
  tenantId      String
  name          String
  description   String?
  type          String             @default("team") // team, direct, department, project
  department    String?            // For department channels
  createdBy     String?
  isArchived    Boolean            @default(false)
  lastMessageAt DateTime @db.TimestampTz?
  lastMessage   String?
  createdAt     DateTime @db.TimestampTz           @default(now())
  updatedAt     DateTime @db.TimestampTz           @updatedAt
  members       StaffChannelMember[]
  messages      StaffChatMessage[]
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([department])
}

/// Staff Channel Member - Channel membership for users
model StaffChannelMember {
  id           String       @id @default(uuid_generate_v4()) @db.Uuid
  channelId    String
  userId       String
  role         String       @default("member") // admin, member
  lastReadAt   DateTime @db.TimestampTz?
  muted        Boolean      @default(false)
  joinedAt     DateTime @db.TimestampTz     @default(now())
  channel      StaffChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

/// Staff Chat Message - Messages in staff communication channels
model StaffChatMessage {
  id           String       @id @default(uuid_generate_v4()) @db.Uuid
  channelId    String
  senderId     String
  content      String
  messageType  String       @default("text") // text, image, file, system
  attachments  String       @default("[]") // JSON array of attachment URLs
  replyToId    String?      // For threaded replies
  isEdited     Boolean      @default(false)
  editedAt     DateTime @db.TimestampTz?
  isDeleted    Boolean      @default(false)
  deletedAt    DateTime @db.TimestampTz?
  sentAt       DateTime @db.TimestampTz     @default(now())
  readBy       String       @default("[]") // JSON array of user IDs who read
  createdAt    DateTime @db.TimestampTz     @default(now())
  updatedAt    DateTime @db.TimestampTz     @updatedAt
  channel      StaffChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  replyTo      StaffChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      StaffChatMessage[] @relation("MessageReplies")

  @@index([channelId])
  @@index([senderId])
  @@index([sentAt])
}

/// GDPR Request - Track data subject requests for GDPR compliance
model GDPRRequest {
  id                String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId          String
  guestId           String?   // The guest whose data is being requested
  requestType       String    // export, delete, anonymize, rectify, restrict
  status            String    @default("pending") // pending, processing, completed, rejected, failed
  requestSource     String    @default("guest") // guest, admin, system, third_party
  requesterEmail    String?   // Email of the person making the request
  requesterName     String?   // Name of the person making the request
  verificationToken String?   // Token for email verification
  verifiedAt        DateTime @db.TimestampTz? // When the request was verified
  expiresAt         DateTime @db.TimestampTz? // Request expiration date (30 days by default)
  priority          String    @default("normal") // low, normal, high, urgent
  notes             String?   // Admin notes
  rejectionReason   String?   // Reason if rejected
  completedAt       DateTime @db.TimestampTz? // When the request was completed
  completedBy       String?   // Admin who completed the request
  downloadUrl       String?   // URL to download exported data
  downloadExpiresAt DateTime @db.TimestampTz? // When the download link expires
  dataSnapshot      String?   // JSON snapshot of data before action (for audit)
  metadata          String    @default("{}") // Additional metadata as JSON
  createdAt         DateTime @db.TimestampTz  @default(now())
  updatedAt         DateTime @db.TimestampTz  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
}

/// Consent Record - Track consent for data processing activities
model ConsentRecord {
  id                String    @id @default(uuid_generate_v4()) @db.Uuid
  tenantId          String
  guestId           String?   // Guest who gave consent
  userId            String?   // User who gave consent (for staff)
  consentType       String    // marketing, analytics, third_party, cookies, essential, profiling
  consentCategory   String    @default("preferences") // preferences, marketing, analytics, third_party, essential
  granted           Boolean   @default(false)
  grantedAt         DateTime @db.TimestampTz?
  grantedVia        String?   // web, mobile, email, api, portal
  ipAddress         String?   // IP address when consent was given
  userAgent         String?   // User agent when consent was given
  consentText       String?   // The text shown to the user
  consentVersion    String?   // Version of the consent text
  revoked           Boolean   @default(false)
  revokedAt         DateTime @db.TimestampTz?
  revokedVia        String?   // web, mobile, email, api, portal
  revocationReason  String?   // Reason for revocation
  expiresAt         DateTime @db.TimestampTz? // When consent expires
  metadata          String    @default("{}") // Additional metadata as JSON
  createdAt         DateTime @db.TimestampTz  @default(now())
  updatedAt         DateTime @db.TimestampTz  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([userId])
  @@index([consentType])
  @@index([granted])
  @@index([createdAt])
}

/// SSO Connection - Enterprise Single Sign-On connections
model SSOConnection {
  id                String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId          String
  name              String
  type              String   // saml, ldap, oidc
  status            String   @default("active") // active, inactive, testing, error
  
  // SAML 2.0 fields
  samlEntityId      String?
  samlSsoUrl        String?
  samlSloUrl        String?
  samlCertificate   String?
  samlPrivateKey    String?
  samlNameIdFormat  String?  @default("urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress")
  samlSignRequest   Boolean  @default(true)
  samlWantAssertionSigned Boolean @default(true)
  
  // LDAP/Active Directory fields
  ldapUrl           String?
  ldapBaseDn        String?
  ldapBindDn        String?
  ldapBindPassword  String?
  ldapSearchFilter  String?  @default("(mail={email})")
  ldapUseStartTls   Boolean  @default(false)
  ldapUseSsl        Boolean  @default(true)
  ldapTimeout       Int      @default(30)
  
  // OIDC fields
  oidcClientId      String?
  oidcClientSecret  String?
  oidcDiscoveryUrl  String?
  oidcAuthorizationUrl String?
  oidcTokenUrl      String?
  oidcUserInfoUrl   String?
  oidcJwksUrl       String?
  oidcScopes        String   @default("openid profile email")
  oidcUsePkce       Boolean  @default(true)
  
  // User attribute mapping
  emailAttribute    String   @default("email")
  firstNameAttribute String  @default("givenName")
  lastNameAttribute String   @default("sn")
  nameAttribute     String   @default("name")
  roleAttribute     String?
  departmentAttribute String?
  phoneAttribute    String?  @default("telephoneNumber")
  
  // Auto provisioning settings
  autoProvision     Boolean  @default(true)
  autoProvisionRole String?  // Default role for provisioned users
  syncRoles         Boolean  @default(false)
  syncOnLogin       Boolean  @default(true)
  
  // Domain restriction
  allowedDomains    String?  // JSON array of allowed domains
  
  // Metadata
  lastSyncAt        DateTime @db.TimestampTz?
  lastSyncStatus    String?
  lastSyncError     String?
  testConnectionAt  DateTime @db.TimestampTz?
  testConnectionStatus String?
  
  createdAt         DateTime @db.TimestampTz @default(now())
  updatedAt         DateTime @db.TimestampTz @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions          SSOSession[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
}

/// SSO Session - Track SSO authentication sessions
model SSOSession {
  id              String   @id @default(uuid_generate_v4()) @db.Uuid
  connectionId    String
  userId          String?
  ssoProviderId   String?  // User ID from the SSO provider
  attributes      String   @default("{}") // JSON: SSO attributes received
  sessionId       String?  // Reference to Session model
  ipAddress       String?
  userAgent       String?
  initiatedAt     DateTime @db.TimestampTz @default(now())
  authenticatedAt DateTime @db.TimestampTz?
  expiresAt       DateTime @db.TimestampTz
  terminatedAt    DateTime @db.TimestampTz?
  terminatedReason String?
  createdAt       DateTime @db.TimestampTz @default(now())
  updatedAt       DateTime @db.TimestampTz @updatedAt
  connection      SSOConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([connectionId])
  @@index([userId])
  @@index([ssoProviderId])
  @@index([sessionId])
  @@index([expiresAt])
}

/// Usage Log - Track individual API calls, messages, and storage operations
model UsageLog {
  id          String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId    String
  type        String   // api_call, message, storage_upload, email, sms, webhook
