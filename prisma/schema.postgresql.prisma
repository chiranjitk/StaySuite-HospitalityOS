  deviceId    String
  command     String
  parameters  String    @default("{}")
  status      String    @default("pending")
  executedAt  DateTime @db.TimestampTz?
  error       String?
  source      String    @default("manual")
  triggeredBy String?
  createdAt   DateTime @db.TimestampTz  @default(now())
  device      IoTDevice @relation(fields: [deviceId], references: [id])

  @@index([deviceId])
  @@index([status])
}

model EnergyMetric {
  id              String   @id @default(uuid_generate_v4()) @db.Uuid
  tenantId        String
  propertyId      String
  date            DateTime @db.TimestampTz
  electricityKwh  Float    @default(0)
  gasM3           Float    @default(0)
  waterM3         Float    @default(0)
  electricityCost Float    @default(0)
  gasCost         Float    @default(0)
  waterCost       Float    @default(0)
  carbonFootprint Float    @default(0)
  createdAt       DateTime @db.TimestampTz @default(now())
  property        Property @relation(fields: [propertyId], references: [id])
  tenant          Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([propertyId, date])
  @@index([tenantId])
  @@index([date])
}

/// WiFi User - PMS managed WiFi credentials for guests
model WiFiUser {
  id               String     @id @default(uuid_generate_v4()) @db.Uuid
  tenantId         String
  propertyId       String
  username         String     @unique
  password         String
  guestId          String?
  bookingId        String?
  userType         String     @default("guest")
  planId           String?
  validFrom        DateTime @db.TimestampTz
  validUntil       DateTime @db.TimestampTz
  maxSessions      Int        @default(1)
  sessionCount     Int        @default(0)
  totalBytesIn     Int        @default(0)
  totalBytesOut    Int        @default(0)
  status           String     @default("active")
  radiusSynced     Boolean    @default(false)
  radiusSyncedAt   DateTime @db.TimestampTz?
  lastAccountingAt DateTime @db.TimestampTz?
  createdAt        DateTime @db.TimestampTz   @default(now())
  updatedAt        DateTime @db.TimestampTz   @updatedAt
  radCheck         RadCheck[]
  radReply         RadReply[]
  plan             WiFiPlan?  @relation(fields: [planId], references: [id])
  property         Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([username])
  @@index([guestId])
  @@index([bookingId])
  @@index([status])
}

/// RadCheck - RADIUS authentication table (FreeRADIUS SQL module)
model RadCheck {
  id         String    @id @default(uuid_generate_v4()) @db.Uuid
  wifiUserId String?
  username   String
  attribute  String
  op         String    @default(":=")
  value      String
  priority   Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime @db.TimestampTz  @default(now())
  updatedAt  DateTime @db.TimestampTz  @updatedAt
  wifiUser   WiFiUser? @relation(fields: [wifiUserId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([attribute])
}

/// RadReply - RADIUS authorization/reply attributes (FreeRADIUS SQL module)
model RadReply {
  id         String    @id @default(uuid_generate_v4()) @db.Uuid
  wifiUserId String?
  username   String
  attribute  String
  op         String    @default(":=")
  value      String
  priority   Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime @db.TimestampTz  @default(now())
  updatedAt  DateTime @db.TimestampTz  @updatedAt
  wifiUser   WiFiUser? @relation(fields: [wifiUserId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([attribute])
}

/// RadAcct - RADIUS accounting table (FreeRADIUS SQL module)
/// This table is written by FreeRADIUS, read by PMS for sync
model RadAcct {
  radacctid          String    @id @default(uuid_generate_v4()) @db.Uuid
  acctsessionid      String
  acctuniqueid       String    @unique
  username           String
  nasipaddress       String
  nasportid          String?
  nasporttype        String?
  acctstarttime      DateTime @db.TimestampTz
  acctstoptime       DateTime @db.TimestampTz?
  acctsessiontime    Int?      @default(0)
  acctauthentic      String?
  connectinfo_start  String?
  connectinfo_stop   String?
  framedipaddress    String?
  framedipv6address  String?
  callingstationid   String?
  calledstationid    String?
  acctinputoctets    Int       @default(0)
  acctoutputoctets   Int       @default(0)
  acctinputpackets   Int       @default(0)
  acctoutputpackets  Int       @default(0)
  acctterminatecause String?
  acctstatus         String    @default("start")
  createdAt          DateTime @db.TimestampTz  @default(now())
  updatedAt          DateTime @db.TimestampTz  @updatedAt

  @@index([username])
  @@index([acctstarttime])
  @@index([acctstoptime])
  @@index([acctstatus])
  @@index([framedipaddress])
  @@index([callingstationid])
}

/// RadUserGroup - User to group mapping (FreeRADIUS SQL module)
model RadUserGroup {
  id        String   @id @default(uuid_generate_v4()) @db.Uuid
  username  String
  groupname String
  priority  Int      @default(0)
  createdAt DateTime @db.TimestampTz @default(now())

  @@index([username])
  @@index([groupname])
}

/// RadGroupCheck - Group-level check attributes
model RadGroupCheck {
