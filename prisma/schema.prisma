/// MultiWanConfig - Multi-WAN load balancing configuration
model MultiWanConfig {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String    @unique @db.Uuid
  enabled         Boolean   @default(false)
  mode            String    @default("weighted") // weighted, failover, round-robin, ECMP
  healthCheckUrl  String    @default("https://1.1.1.1")
  healthCheckInterval Int   @default(10) // seconds
  healthCheckTimeout  Int   @default(3) // seconds
  failoverThreshold Int   @default(3) // consecutive failures
  autoSwitchback  Boolean   @default(true)
  switchbackDelay Int       @default(300) // seconds
  flushConnectionsOnFailover Boolean @default(true)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wanMembers      MultiWanMember[]

  @@index([tenantId])
}


/// MultiWanMember - Individual WAN interface in multi-WAN config
model MultiWanMember {
  id              String    @id @default(uuid()) @db.Uuid
  multiWanConfigId String @db.Uuid
  interfaceName   String    // eth0, eth1, bond0
  interfaceId     String? @db.Uuid   // FK to NetworkInterface
  weight          Int       @default(1) // For weighted load balancing (1-100)
  gateway         String?   // Gateway IP
  healthStatus    String    @default("unknown") // online, offline, checking, unknown
  lastHealthCheck DateTime? @db.Timestamptz
  enabled         Boolean   @default(true)
  isPrimary       Boolean   @default(false)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  multiWanConfig  MultiWanConfig @relation(fields: [multiWanConfigId], references: [id], onDelete: Cascade)

  @@unique([multiWanConfigId, interfaceName])
  @@index([multiWanConfigId])
}


/// NasHealthLog - NAS health monitoring history (Accsium tblnasconnectivity)
model NasHealthLog {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  nasIpAddress    String
  nasName         String?
  isOnline        Boolean   @default(false)
  liveUsers       Int       @default(0)
  totalAuths       Int       @default(0)
  totalAccts       Int       @default(0)
  avgLatencyMs    Float?
  lastSeenAt       DateTime? @db.Timestamptz
  checkIntervalSec Int       @default(60)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([nasIpAddress])
  @@index([isOnline])
  @@index([createdAt])
}

model NasReload {
  nasipaddress String   @id
  reloadtime  DateTime  @db.Timestamptz

  @@map("nasreload")
}

