/// This table is written by FreeRADIUS, read by PMS for sync
model RadAcct {
  radacctid          String    @id @default(cuid())
  acctsessionid      String
  acctuniqueid       String    @unique
  username           String
  nasipaddress       String
  nasportid          String?
  nasporttype        String?
