/// NetworkInterface - Physical/virtual network interface on the gateway server
model NetworkInterface {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  name            String    // eth0, eth1, lo, wlan0
  type            String    @default("ethernet") // ethernet, vlan, bridge, bond, alias, loopback, wireless
  hwAddress       String?   // MAC address
  mtu             Int       @default(1500)
  speed           String?   // 1000M, 2500M, 10000M
  status          String    @default("down") // up, down, unknown
  carrier         Boolean   @default(false)
  isManagement    Boolean   @default(false)
  description     String?
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles           InterfaceRole[]
  vlans           VlanConfig[]
  bondMembers     BondMember[]
  aliases         InterfaceAlias[]

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
}

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String @db.Uuid
  userId       String @db.Uuid
  type         String    // booking, payment, housekeeping, maintenance, system, etc.
  category     String    // info, warning, success, error
  title        String
  message      String
  data         String    @default("{}") // JSON: Additional context data
  link         String?   // URL to navigate when clicked
  icon         String?   // Icon name or URL
  image        String?   // Optional image URL
  priority     String    @default("normal") // low, normal, high, urgent
  readAt       DateTime? @db.Timestamptz
  dismissedAt  DateTime? @db.Timestamptz
  actionType   String?   // Type of action button (view, accept, dismiss, etc.)
  actionData   String?   // JSON: Action-specific data
  expiresAt    DateTime? @db.Timestamptz
  createdAt    DateTime @db.Timestamptz  @default(now())
  updatedAt    DateTime @db.Timestamptz  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@index([expiresAt])
}

model NotificationLog {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String @db.Uuid
  templateId     String? @db.Uuid
  recipientType  String
  recipientId    String @db.Uuid
  recipientEmail String?
  recipientPhone String?
  channel        String
  subject        String?
  body           String
  status         String    @default("pending")
  errorMessage   String?
  externalId     String? @db.Uuid
  retryCount     Int       @default(0)
  sentAt         DateTime? @db.Timestamptz
  deliveredAt    DateTime? @db.Timestamptz
  createdAt      DateTime @db.Timestamptz  @default(now())

  @@index([tenantId])
  @@index([recipientId])
  @@index([status])
}

model NotificationPreference {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  userId          String @db.Uuid
  category        String   // booking, payment, housekeeping, marketing, system, etc.
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(true)
  pushEnabled     Boolean  @default(true)
