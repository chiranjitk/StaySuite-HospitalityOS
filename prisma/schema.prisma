  userAgent    String?
  isActive     Boolean  @default(true)
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([token])
  @@index([isActive])
}

/// LoyaltyTier - Configurable loyalty tier levels
model LoyaltyTier {
  id               String   @id @default(cuid())
  tenantId         String
  name             String   // bronze, silver, gold, platinum
  displayName      String   // Bronze Member, Silver Elite, etc.
  minPoints        Int      @default(0)
  maxPoints        Int?     // null means no upper limit
  pointsMultiplier Float    @default(1.0) // earn rate multiplier
  benefits         String   @default("[]") // JSON array of benefit strings
  color            String   @default("#cd7f32") // tier color for UI
  icon             String?  // optional icon name
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([minPoints])
}

/// LoyaltyReward - Rewards available for point redemption
model LoyaltyReward {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  description        String?
  category           String   @default("general") // general, room, dining, spa, experience
  pointsCost         Int
  monetaryValue      Float    @default(0) // equivalent monetary value for reporting
  currency           String   @default("USD")
  imageUrl           String?
  isAvailable        Boolean  @default(true)
  availableFrom      DateTime?
  availableUntil     DateTime?
  maxRedemptions     Int?     // null means unlimited
  currentRedemptions Int      @default(0)
  minTierRequired    String?  // minimum tier name required to redeem
  termsConditions    String?
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions        LoyaltyRedemption[]

  @@index([tenantId])
  @@index([category])
  @@index([isAvailable])
}

/// LoyaltyRedemption - Record of point redemptions
model LoyaltyRedemption {
  id              String   @id @default(cuid())
  tenantId        String
  guestId         String
  rewardId        String
  pointsSpent     Int
  status          String   @default("completed") // pending, completed, cancelled, expired
  redemptionCode  String?  @unique // code to claim the reward
  redeemedAt      DateTime @default(now())
  expiresAt       DateTime?
  cancelledAt     DateTime?
  cancelledReason String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  guest           Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reward          LoyaltyReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([rewardId])
  @@index([status])
  @@index([redemptionCode])
}

/// LoyaltyPointTransaction - Track all point movements
model LoyaltyPointTransaction {
  id             String   @id @default(cuid())
  tenantId       String
  guestId        String
  points         Int      // positive for earn, negative for redeem
  balance        Int      // balance after transaction
  type           String   // earn, redeem, expire, adjust, bonus, referral
  source         String?  // booking, promotion, manual, etc.
  referenceId    String?  // related entity id (booking, redemption, etc.)
  referenceType  String?  // booking, redemption, etc.
  description    String?
  expiresAt      DateTime? // for points that expire
  createdAt      DateTime @default(now())
  guest          Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([type])
  @@index([expiresAt])
}

/// BankAccount - Hotel bank accounts for reconciliation
model BankAccount {
  id                 String            @id @default(cuid())
  tenantId           String
  propertyId         String?
  accountName        String
  accountNumber      String            // Masked or encrypted
  bankName           String
  bankCode           String?           // IFSC, SWIFT, Routing number, etc.
  accountType        String            @default("checking") // checking, savings, money_market
  currency           String            @default("USD")
  openingBalance     Float             @default(0)
  currentBalance     Float             @default(0)
  lastReconciledAt   DateTime?
  lastStatementDate  DateTime?
  status             String            @default("active") // active, closed, frozen
  isDefault          Boolean           @default(false)
  notes              String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  transactions       BankTransaction[]
  reconciliations    Reconciliation[]
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankName])
  @@index([status])
}

/// BankTransaction - Transactions from bank statements
model BankTransaction {
  id                String            @id @default(cuid())
  tenantId          String
  bankAccountId     String
  transactionDate   DateTime
  valueDate         DateTime?         // Value date (may differ from transaction date)
  transactionType   String            // debit, credit
  amount            Float
  currency          String            @default("USD")
  balance           Float?            // Balance after transaction
  description       String?
  reference         String?           // Bank reference number
  chequeNumber      String?
  payeeName         String?
  payeeAccount      String?
  category          String?           // User-defined category
  subCategory       String?
  isReconciled      Boolean           @default(false)
  reconciledAt      DateTime?
  importSource      String            @default("manual") // manual, csv, api, ofx
  importBatchId     String?           // Batch ID for bulk imports
  rawLine           String?           // Original line from import
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  bankAccount       BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliations   Reconciliation[]
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isReconciled])
  @@index([transactionType])
  @@index([importBatchId])
}

/// Reconciliation - Matching bank transactions to payments
model Reconciliation {
  id                    String          @id @default(cuid())
  tenantId              String
  bankAccountId         String
  bankTransactionId     String
  paymentId             String?         // Matched payment from PMS
  folioId               String?         // Matched folio
  matchType             String          @default("manual") // auto, manual, partial
  matchConfidence       Float?          // Confidence score for auto-matching (0-1)
  matchCriteria         String          @default("{}") // JSON: matched fields
  status                String          @default("matched") // matched, unmatched, disputed, adjusted
  reconciledAmount      Float           // Amount reconciled (may differ from transaction)
  adjustmentAmount      Float           @default(0) // Difference if any
  adjustmentReason      String?
  reconciledBy          String?         // User who performed reconciliation
  reconciledAt          DateTime        @default(now())
  notes                 String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  bankAccount           BankAccount     @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  bankTransaction       BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  tenant                Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([bankTransactionId])
  @@index([paymentId])
  @@index([status])
  @@index([reconciledAt])
}

/// TaxReport - Tax reports for different jurisdictions
model TaxReport {
  id                  String    @id @default(cuid())
  tenantId            String
  propertyId          String?
  reportNumber        String    @unique
  reportType          String    // gst, vat, sales_tax, occupancy_tax, service_tax
  jurisdiction        String    @default("india") // india, us, eu, uk, canada, australia, etc.
  periodStart         DateTime
  periodEnd           DateTime
  filingDueDate       DateTime?
  grossRevenue        Float     @default(0)
  taxableRevenue      Float     @default(0)
  taxCollected        Float     @default(0)
  taxPaid             Float     @default(0)
  taxDue              Float     @default(0)
  taxRefundable       Float     @default(0)
  adjustments         Float     @default(0)
  adjustmentReason    String?
  // For Indian GST
  cgstAmount          Float     @default(0) // Central GST
  sgstAmount          Float     @default(0) // State GST
  igstAmount          Float     @default(0) // Integrated GST
  cessAmount          Float     @default(0) // Cess
  // For US Sales Tax
  stateTaxAmount      Float     @default(0)
  localTaxAmount      Float     @default(0)
  // For VAT
  vatOutput          Float     @default(0) // VAT collected
  vatInput           Float     @default(0) // VAT paid (input credit)
  // Reporting details
  transactionCount    Int       @default(0)
  exemptTransactions  Int       @default(0)
  exportTransactions  Int       @default(0)
  // Status and filing
  status              String    @default("draft") // draft, submitted, filed, paid, audited
  filedAt             DateTime?
  filedBy             String?
  filingReference     String?   // Government acknowledgment number
  paymentReference    String?
  paidAt              DateTime?
  // Attachments and notes
  attachmentUrl       String?
  notes               String?
  internalNotes       String?
  // Audit trail
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([reportType])
  @@index([jurisdiction])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([filingDueDate])
}


/// Staff Communication Channel - Internal team channels for staff communication
model StaffChannel {
  id            String             @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  type          String             @default("team") // team, direct, department, project
  department    String?            // For department channels
  createdBy     String?
  isArchived    Boolean            @default(false)
  lastMessageAt DateTime?
  lastMessage   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  members       StaffChannelMember[]
  messages      StaffChatMessage[]
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([department])
}

/// Staff Channel Member - Channel membership for users
model StaffChannelMember {
  id           String       @id @default(cuid())
  channelId    String
  userId       String
  role         String       @default("member") // admin, member
  lastReadAt   DateTime?
  muted        Boolean      @default(false)
  joinedAt     DateTime     @default(now())
  channel      StaffChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
}

/// Staff Chat Message - Messages in staff communication channels
model StaffChatMessage {
  id           String       @id @default(cuid())
  channelId    String
  senderId     String
  content      String
  messageType  String       @default("text") // text, image, file, system
  attachments  String       @default("[]") // JSON array of attachment URLs
  replyToId    String?      // For threaded replies
  isEdited     Boolean      @default(false)
  editedAt     DateTime?
  isDeleted    Boolean      @default(false)
  deletedAt    DateTime?
  sentAt       DateTime     @default(now())
  readBy       String       @default("[]") // JSON array of user IDs who read
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  channel      StaffChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])
  replyTo      StaffChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      StaffChatMessage[] @relation("MessageReplies")

  @@index([channelId])
  @@index([senderId])
  @@index([sentAt])
}

/// GDPR Request - Track data subject requests for GDPR compliance
model GDPRRequest {
  id                String    @id @default(cuid())
  tenantId          String
  guestId           String?   // The guest whose data is being requested
  requestType       String    // export, delete, anonymize, rectify, restrict
  status            String    @default("pending") // pending, processing, completed, rejected, failed
  requestSource     String    @default("guest") // guest, admin, system, third_party
  requesterEmail    String?   // Email of the person making the request
  requesterName     String?   // Name of the person making the request
  verificationToken String?   // Token for email verification
  verifiedAt        DateTime? // When the request was verified
  expiresAt         DateTime? // Request expiration date (30 days by default)
  priority          String    @default("normal") // low, normal, high, urgent
  notes             String?   // Admin notes
  rejectionReason   String?   // Reason if rejected
  completedAt       DateTime? // When the request was completed
  completedBy       String?   // Admin who completed the request
  downloadUrl       String?   // URL to download exported data
  downloadExpiresAt DateTime? // When the download link expires
  dataSnapshot      String?   // JSON snapshot of data before action (for audit)
  metadata          String    @default("{}") // Additional metadata as JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([requestType])
  @@index([status])
  @@index([createdAt])
  @@index([expiresAt])
}

/// Consent Record - Track consent for data processing activities
model ConsentRecord {
  id                String    @id @default(cuid())
  tenantId          String
  guestId           String?   // Guest who gave consent
  userId            String?   // User who gave consent (for staff)
  consentType       String    // marketing, analytics, third_party, cookies, essential, profiling
  consentCategory   String    @default("preferences") // preferences, marketing, analytics, third_party, essential
  granted           Boolean   @default(false)
  grantedAt         DateTime?
  grantedVia        String?   // web, mobile, email, api, portal
  ipAddress         String?   // IP address when consent was given
  userAgent         String?   // User agent when consent was given
  consentText       String?   // The text shown to the user
  consentVersion    String?   // Version of the consent text
  revoked           Boolean   @default(false)
  revokedAt         DateTime?
  revokedVia        String?   // web, mobile, email, api, portal
  revocationReason  String?   // Reason for revocation
  expiresAt         DateTime? // When consent expires
  metadata          String    @default("{}") // Additional metadata as JSON
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([userId])
  @@index([consentType])
  @@index([granted])
  @@index([createdAt])
}

/// SSO Connection - Enterprise Single Sign-On connections
model SSOConnection {
  id                String   @id @default(cuid())
  tenantId          String
  name              String
  type              String   // saml, ldap, oidc
  status            String   @default("active") // active, inactive, testing, error
  
  // SAML 2.0 fields
  samlEntityId      String?
  samlSsoUrl        String?
  samlSloUrl        String?
  samlCertificate   String?
  samlPrivateKey    String?
  samlNameIdFormat  String?  @default("urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress")
  samlSignRequest   Boolean  @default(true)
  samlWantAssertionSigned Boolean @default(true)
  
  // LDAP/Active Directory fields
  ldapUrl           String?
  ldapBaseDn        String?
  ldapBindDn        String?
  ldapBindPassword  String?
  ldapSearchFilter  String?  @default("(mail={email})")
  ldapUseStartTls   Boolean  @default(false)
  ldapUseSsl        Boolean  @default(true)
  ldapTimeout       Int      @default(30)
  
  // OIDC fields
  oidcClientId      String?
  oidcClientSecret  String?
  oidcDiscoveryUrl  String?
  oidcAuthorizationUrl String?
  oidcTokenUrl      String?
  oidcUserInfoUrl   String?
  oidcJwksUrl       String?
  oidcScopes        String   @default("openid profile email")
  oidcUsePkce       Boolean  @default(true)
  
  // User attribute mapping
  emailAttribute    String   @default("email")
  firstNameAttribute String  @default("givenName")
  lastNameAttribute String   @default("sn")
  nameAttribute     String   @default("name")
  roleAttribute     String?
  departmentAttribute String?
  phoneAttribute    String?  @default("telephoneNumber")
  
  // Auto provisioning settings
  autoProvision     Boolean  @default(true)
  autoProvisionRole String?  // Default role for provisioned users
  syncRoles         Boolean  @default(false)
  syncOnLogin       Boolean  @default(true)
  
  // Domain restriction
  allowedDomains    String?  // JSON array of allowed domains
  
  // Metadata
  lastSyncAt        DateTime?
  lastSyncStatus    String?
  lastSyncError     String?
  testConnectionAt  DateTime?
  testConnectionStatus String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions          SSOSession[]

  @@index([tenantId])
  @@index([type])
  @@index([status])
}

/// SSO Session - Track SSO authentication sessions
model SSOSession {
  id              String   @id @default(cuid())
  connectionId    String
  userId          String?
  ssoProviderId   String?  // User ID from the SSO provider
  attributes      String   @default("{}") // JSON: SSO attributes received
  sessionId       String?  // Reference to Session model
  ipAddress       String?
  userAgent       String?
  initiatedAt     DateTime @default(now())
  authenticatedAt DateTime?
  expiresAt       DateTime
  terminatedAt    DateTime?
  terminatedReason String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  connection      SSOConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([connectionId])
  @@index([userId])
  @@index([ssoProviderId])
  @@index([sessionId])
  @@index([expiresAt])
}

/// Usage Log - Track individual API calls, messages, and storage operations
model UsageLog {
  id          String   @id @default(cuid())
  tenantId    String
  type        String   // api_call, message, storage_upload, email, sms, webhook
  endpoint    String?  // API endpoint or operation name
  method      String?  // HTTP method for API calls
  statusCode  Int?     // HTTP status code
  dataSize    Int      @default(0) // Size in bytes for storage operations
  duration    Int?     // Duration in milliseconds
  ipAddress   String?
  userAgent   String?
  userId      String?
  metadata    String   @default("{}") // JSON: additional metadata
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
  @@index([tenantId, type, createdAt])
}

/// Usage Summary - Aggregated usage statistics per tenant per day
model UsageSummary {
  id                  String   @id @default(cuid())
  tenantId            String   @unique
  apiCalls            Int      @default(0)
  apiCallsMonth       Int      @default(0)
  messagesSent        Int      @default(0)
  messagesMonth       Int      @default(0)
  emailsSent          Int      @default(0)
  emailsMonth         Int      @default(0)
  smsSent             Int      @default(0)
  smsMonth            Int      @default(0)
  storageUsedMb       Float    @default(0)
  storageFiles        Int      @default(0)
  webhooksSent        Int      @default(0)
  webhooksMonth       Int      @default(0)
  lastApiCallAt       DateTime?
  lastMessageAt       DateTime?
  lastStorageUploadAt DateTime?
  lastResetAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([lastResetAt])
}

/// SecurityEvent - Camera-triggered security events with severity and acknowledgement tracking
/// Multi-tenant: scoped by tenantId, linked to Camera
model SecurityEvent {
  id              String    @id @default(cuid())
  tenantId        String
  cameraId        String
  type            String
  severity        String    @default("medium")
  description     String?
  thumbnail       String?
  recordingId     String?
  metadata        String    @default("{}")
  timestamp       DateTime  @default(now())
  acknowledged    Boolean   @default(false)
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  camera          Camera    @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cameraId])
  @@index([severity])
  @@index([timestamp])
  @@index([acknowledged])
}

/// ChannelRetryQueue - Failed channel sync operations pending retry with exponential backoff
/// Multi-tenant: scoped by tenantId
model ChannelRetryQueue {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String?
  syncLogId       String?
  channelCode     String
  operation       String
  payload         String    @default("{}")
  attemptCount    Int       @default(0)
  nextRetryAt     DateTime
  status          String    @default("pending")
  lastError       String?
  lastAttemptAt   DateTime?
  priority        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([nextRetryAt])
  @@index([channelCode])
}

/// ChannelDeadLetterQueue - Failed channel operations that exceeded max retry attempts
/// Multi-tenant: scoped by tenantId
model ChannelDeadLetterQueue {
  id                 String    @id @default(cuid())
  tenantId           String
  propertyId         String?
  syncLogId          String?
  channelCode        String
  operation          String
  payload            String    @default("{}")
  error              String
  attemptCount       Int       @default(0)
  originalCreatedAt  DateTime
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  tenant             Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([channelCode])
  @@index([createdAt])
}

/// ExternalReview - Reviews from external platforms (Booking.com, Google, TripAdvisor, etc.)
/// Multi-tenant: scoped by tenantId, optionally linked to propertyId
model ExternalReview {
  id                String    @id @default(cuid())
  tenantId          String
  propertyId        String?
  source            String    @default("unknown")
  externalId        String?
  content           String
  rating            Int
  reviewerName      String?
  reviewDate        DateTime  @default(now())
  sentimentScore    Float?
  sentimentLabel    String?
  sentimentAspects  String?
  sentimentKeywords String?
  responseText      String?
  respondedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  property          Property? @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([source])
  @@index([reviewDate])
}

// ============================================================
// NETWORK GATEWAY MODULE - System as Gateway
// ============================================================

/// NetworkInterface - Physical/virtual network interface on the gateway server
model NetworkInterface {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String    // eth0, eth1, lo, wlan0
  type            String    @default("ethernet") // ethernet, vlan, bridge, bond, alias, loopback, wireless
  hwAddress       String?   // MAC address
  mtu             Int       @default(1500)
  speed           String?   // 1000M, 2500M, 10000M
  status          String    @default("down") // up, down, unknown
  carrier         Boolean   @default(false)
  isManagement    Boolean   @default(false)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles           InterfaceRole[]
  vlans           VlanConfig[]
  bondMembers     BondMember[]
  aliases         InterfaceAlias[]

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
}

/// InterfaceRole - WAN/LAN/DMZ assignment for each interface
model InterfaceRole {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  interfaceId     String
  role            String    @default("lan") // wan, lan, dmz, management, wifi, unused
  priority        Int       @default(0) // For WAN failover ordering
  isPrimary       Boolean   @default(false)
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  networkInterface NetworkInterface @relation(fields: [interfaceId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, interfaceId])
  @@index([tenantId])
  @@index([propertyId])
  @@index([role])
}

/// InterfaceConfig - IP configuration per interface
model InterfaceConfig {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  interfaceId     String
  mode            String    @default("static") // static, dhcp, disabled
  ipAddress       String?
  netmask         String?   // 255.255.255.0 or CIDR prefix length
  gateway         String?
  dnsPrimary      String?
  dnsSecondary    String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, interfaceId])
  @@index([tenantId])
  @@index([propertyId])
}

/// VlanConfig - VLAN configuration on parent interfaces
model VlanConfig {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  parentInterfaceId String
  vlanId          Int
  subInterface    String    // eth0.100
  description     String?
  mtu             Int       @default(1500)
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  parentInterface NetworkInterface @relation(fields: [parentInterfaceId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dhcpSubnets     DhcpSubnet[]
  captivePortals  CaptivePortal[]

  @@unique([propertyId, vlanId])
  @@unique([propertyId, subInterface])
  @@index([tenantId])
  @@index([propertyId])
}

/// BridgeConfig - Network bridge configuration
model BridgeConfig {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String    // br0, br-guest
  memberInterfaces String   @default("[]") // JSON: ["eth1","eth2"]
  stpEnabled      Boolean   @default(false)
  forwardDelay    Int       @default(15)
  helloTime       Int       @default(2)
  maxAge          Int       @default(20)
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}

/// BondConfig - Link aggregation / bonding configuration
model BondConfig {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String    // bond0
  mode            String    @default("active-backup") // active-backup, balance-rr, balance-xor, 802.3ad, balance-tlb, balance-alb
  miimon          Int       @default(100)
  lacpRate        String    @default("slow")
  primaryMember   String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members         BondMember[]

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}

/// BondMember - Individual interface in a bond
model BondMember {
  id              String    @id @default(cuid())
  bondConfigId    String
  interfaceId     String
  priority        Int       @default(0)
  createdAt       DateTime  @default(now())
  bondConfig      BondConfig @relation(fields: [bondConfigId], references: [id], onDelete: Cascade)
  networkInterface NetworkInterface @relation(fields: [interfaceId], references: [id], onDelete: Cascade)

  @@unique([bondConfigId, interfaceId])
  @@index([bondConfigId])
}

/// WanFailover - WAN failover configuration
model WanFailover {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  primaryWanId    String
  backupWanId     String
  healthCheckUrl  String    @default("https://1.1.1.1")
  healthCheckInterval Int   @default(30)
  failoverThreshold Int     @default(3)
  autoSwitchback  Boolean   @default(true)
  switchbackDelay Int       @default(300)
  enabled         Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId])
  @@index([tenantId])
}

/// PortForwardRule - NAT port forwarding rules
model PortForwardRule {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  protocol        String    @default("tcp") // tcp, udp, both
  externalPort    Int
  internalIp      String
  internalPort    Int
  interfaceId     String?
  enabled         Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

// ============================================================
// DHCP SERVER MODULE - ISC Kea integration
// ============================================================

/// DhcpSubnet - DHCP subnet configuration
model DhcpSubnet {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  subnet          String    // 192.168.1.0/24
  gateway         String?   // 192.168.1.1
  poolStart       String    // 192.168.1.100
  poolEnd         String    // 192.168.1.254
  leaseTime       Int       @default(3600) // seconds
  vlanId          Int?
  vlanConfigId    String?
  domainName      String?
  dnsServers      String    @default("[]") // JSON: ["8.8.8.8","1.1.1.1"]
  ntpServers      String    @default("[]") // JSON: ["pool.ntp.org"]
  bootFileName    String?
  nextServer      String?
  enabled         Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  vlanConfig      VlanConfig? @relation(fields: [vlanConfigId], references: [id])
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations    DhcpReservation[]
  leases          DhcpLease[]
  dhcpOptions     DhcpOption[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([subnet])
  @@index([enabled])
}

/// DhcpReservation - Static DHCP reservations (known MAC list)
model DhcpReservation {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  subnetId        String
  macAddress      String
  ipAddress       String
  hostname        String?
  leaseTime       Int?      // Override default lease time
  linkedType      String?   // guest, room, device, staff
  linkedId        String?   // Reference to guest/room/device
  description     String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  dhcpSubnet      DhcpSubnet @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([subnetId, macAddress])
  @@unique([subnetId, ipAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([macAddress])
}

/// DhcpLease - Live DHCP lease state (synced from Kea, read-mostly)
model DhcpLease {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  subnetId        String
  macAddress      String
  ipAddress       String
  hostname        String?
  clientId        String?
  leaseStart      DateTime  @default(now())
  leaseEnd        DateTime
  state           String    @default("active") // active, expired, released, declined
  lastSeenAt      DateTime  @default(now())
  subnet          DhcpSubnet @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([subnetId, ipAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([macAddress])
  @@index([state])
  @@index([leaseEnd])
}

/// DhcpOption - Custom DHCP options (global and per-subnet)
model DhcpOption {
  id              String       @id @default(cuid())
  tenantId        String
  propertyId      String
  subnetId        String?      // null = global/property-level option
  code            Int          // DHCP option code (e.g., 6=DNS, 42=NTP, 66=TFTP)
  name            String       // Human-readable name
  value           String       // Option value
  type            String       @default("string") // string, ip, integer, boolean, hex
  enabled         Boolean      @default(true)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  dhcpSubnet      DhcpSubnet?  @relation(fields: [subnetId], references: [id], onDelete: Cascade)
  property        Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([subnetId])
  @@index([code])
}

// ============================================================
// DNS SERVER MODULE - dnsmasq / split-horizon DNS
// ============================================================

/// DnsZone - DNS zone for LAN resolution
model DnsZone {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  domain          String    // staysuite.local, hotel.internal
  description     String?
  vlanId          Int?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  records         DnsRecord[]

  @@unique([propertyId, domain])
  @@index([tenantId])
  @@index([propertyId])
}

/// DnsRecord - Individual DNS record
model DnsRecord {
  id              String    @id @default(cuid())
  tenantId        String
  zoneId          String
  name            String    // pos, spa, portal
  type            String    @default("A") // A, AAAA, CNAME, MX, TXT, SRV, PTR
  value           String    // 192.168.1.10
  ttl             Int       @default(300)
  priority        Int?      // For MX/SRV
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  dnsZone         DnsZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([zoneId, name, type])
  @@index([tenantId])
  @@index([zoneId])
}

/// DnsRedirectRule - DNS redirect for captive portal / content filtering
model DnsRedirectRule {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  matchPattern    String    // * (all domains), *.example.com, or specific domain
  targetIp        String    // Captive portal IP or NXDOMAIN
  applyTo         String    @default("unauthenticated") // unauthenticated, all, authenticated
  priority        Int       @default(0)
  enabled         Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
  @@index([priority])
}

// ============================================================
// CAPTIVE PORTAL MODULE - Full portal management
// ============================================================

/// CaptivePortal - Portal instance configuration
model CaptivePortal {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  description     String?
  listenIp        String    @default("0.0.0.0")
  listenPort      Int       @default(80)
  useSsl          Boolean   @default(false)
  sslCertPath     String?
  sslKeyPath      String?
  enabled         Boolean   @default(true)
  maxConcurrent   Int       @default(1000)
  sessionTimeout  Int       @default(86400)
  idleTimeout     Int       @default(3600)
  redirectUrl     String?
  successMessage  String?
  failMessage     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vlanConfigs     VlanConfig[]
  portalMappings  PortalMapping[]
  authMethods     PortalAuthentication[]
  portalPages     PortalPage[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

/// PortalMapping - Maps portal to subnet/VLAN/SSID
model PortalMapping {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  portalId        String
  vlanId          Int?
  vlanConfigId    String?
  ssid            String?
  subnet          String?
  priority        Int       @default(0)
  fallbackPortalId String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  captivePortal   CaptivePortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([portalId])
  @@index([ssid])
  @@index([enabled])
}

/// PortalPage - Portal page design/styling per portal
model PortalPage {
  id              String    @id @default(cuid())
  tenantId        String
  portalId        String
  language        String    @default("en")
  title           String?
  subtitle        String?
  logoUrl         String?
  backgroundImage String?
  backgroundColor String    @default("#ffffff")
  textColor       String    @default("#1f2937")
  accentColor     String    @default("#0d9488")
  termsText       String?
  termsUrl        String?
  customCss       String    @default("")
  customHtml      String    @default("")
  showSocial      Boolean   @default(false)
  showBranding    Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  captivePortal   CaptivePortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([portalId, language])
  @@index([tenantId])
  @@index([portalId])
}

/// PortalTemplate - Reusable portal design templates
model PortalTemplate {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  category        String    @default("hotel") // hotel, resort, corporate, minimal, cafe, airport
  thumbnail       String?
  htmlContent     String
  cssContent      String
  isBuiltIn       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([category])
}

/// PortalAuthentication - Auth methods per portal
model PortalAuthentication {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  portalId        String
  method          String    @default("voucher") // voucher, room_number, pms_credentials, sms_otp, social, mac_auth, open
  enabled         Boolean   @default(true)
  priority        Int       @default(0)
  config          String    @default("{}") // JSON: method-specific settings
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  captivePortal   CaptivePortal @relation(fields: [portalId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([portalId, method])
  @@index([tenantId])
  @@index([propertyId])
  @@index([portalId])
}

// ============================================================
// FIREWALL & BANDWIDTH MODULE - nftables + tc management
// ============================================================

/// FirewallZone - Logical firewall zone
model FirewallZone {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String    // lan, wan, dmz, guest, staff, iot
  interfaces      String    @default("[]") // JSON: ["eth0","eth1"]
  inputPolicy     String    @default("accept") // accept, drop, reject
  forwardPolicy   String    @default("accept")
  outputPolicy    String    @default("accept")
  masquerade      Boolean   @default(false)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rules           FirewallRule[]

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}

/// FirewallRule - Individual firewall rule
model FirewallRule {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  zoneId          String
  chain           String    @default("input") // input, forward, output, prerouting, postrouting
  protocol        String?   // tcp, udp, icmp, or null for all
  sourceIp        String?
  sourcePort      Int?
  destIp          String?
  destPort        Int?
  action          String    @default("accept") // accept, drop, reject, log, jump
  jumpTarget      String?   // For jump action
  logPrefix       String?
  enabled         Boolean   @default(true)
  comment         String?
  priority        Int       @default(0)
  scheduleId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  firewallZone    FirewallZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([zoneId])
  @@index([enabled])
  @@index([priority])
}

/// FirewallSchedule - Time-based rule activation
model FirewallSchedule {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  daysOfWeek      String    @default("1,2,3,4,5,6,7") // Comma-separated: 1=Mon, 7=Sun
  startTime       String    @default("00:00")
  endTime         String    @default("23:59")
  timezone        String    @default("UTC")
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
}

/// MacFilter - MAC address whitelist/blacklist
model MacFilter {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  macAddress      String
  action          String    @default("allow") // allow, deny
  listType        String    @default("blacklist") // whitelist, blacklist
  description     String?
  linkedType      String?   // guest, staff, device
  linkedId        String?
  expiresAt       DateTime?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, macAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([listType])
  @@index([enabled])
}

/// BandwidthPolicy - BW shaping policy linked to WiFi plans
model BandwidthPolicy {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  downloadKbps    Int       @default(10240) // 10 Mbps default
  uploadKbps      Int       @default(10240)
  burstDownloadKbps Int?
  burstUploadKbps Int?
  priority        Int       @default(5) // 0=highest, 10=lowest
  planId          String?   // Link to WiFiPlan
  description     String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([planId])
  @@index([enabled])
}

/// BandwidthUsageSession - Per-session bandwidth tracking
model BandwidthUsageSession {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  sessionId       String
  username        String?
  ipAddress       String
  macAddress      String?
  planId          String?
  policyId        String?
  downloadBytes   Int       @default(0)
  uploadBytes     Int       @default(0)
  durationSeconds Int       @default(0)
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([startedAt])
  @@index([endedAt])
}

/// BandwidthUsageDaily - Daily aggregate bandwidth stats
model BandwidthUsageDaily {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  date            DateTime
  totalDownloadMb Float     @default(0)
  totalUploadMb   Float     @default(0)
  uniqueUsers     Int       @default(0)
  peakUsers       Int       @default(0)
  peakTime        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@index([tenantId])
  @@index([propertyId])
  @@index([date])
}

// ============================================================
// REPORTING MODULE - Web surfing, NAT logs, syslog
// ============================================================

/// NatLog - NAT/connection tracking logs
model NatLog {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  timestamp       DateTime  @default(now())
  sourceIp        String
  sourcePort      Int
  destIp          String
  destPort        Int
  protocol        String    // tcp, udp
  destDomain      String?   // Resolved domain for reporting
  action          String    @default("allow") // allow, deny
  bytes           Int       @default(0)
  sessionId       String?
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([timestamp])
  @@index([sourceIp])
  @@index([destDomain])
  @@index([sessionId])
}

/// SyslogServer - External syslog forwarding configuration
model SyslogServer {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  protocol        String    @default("udp") // udp, tcp, tls
  host            String
  port            Int       @default(514)
  format          String    @default("ietf") // bsd, ietf, json
  facility        String    @default("local1") // local0-local7, kern, user, etc
  severity        String    @default("info") // emerg, alert, crit, error, warning, notice, info, debug
  categories      String    @default("[]") // JSON: ["auth","firewall","dhcp","dns","portal"]
  enabled         Boolean   @default(false)
  tlsCertPath     String?
  tlsVerify       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

/// ContentFilter - DNS/content filtering categories
model ContentFilter {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  category        String    // social_media, streaming, adult, gaming, malware, ads, custom
  domains         String    @default("[]") // JSON: ["facebook.com","instagram.com"]
  enabled         Boolean   @default(true)
  scheduleId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([category])
  @@index([enabled])
}

/// ScheduleAccess - Time-based WiFi access control
model ScheduleAccess {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  daysOfWeek      String    @default("1,2,3,4,5,6,7")
  startTime       String    @default("00:00")
  endTime         String    @default("23:59")
  applyTo         String    @default("all") // all, guest, staff, specific_plan
  applyToPlanId   String?
  bandwidthPolicyId String?
  action          String    @default("allow") // allow, deny, limit
  description     String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
}

/// BandwidthPool - Shared bandwidth pool per subnet
model BandwidthPool {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  subnet          String?
  vlanId          Int?
  totalDownloadKbps Int     @default(100000) // 100 Mbps
  totalUploadKbps   Int     @default(100000)
  perUserDownloadKbps Int?
  perUserUploadKbps Int?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([vlanId])
  @@index([enabled])
}

/// NetworkConfigBackup - Network configuration backup/restore
model NetworkConfigBackup {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  configData      String    // Full JSON snapshot of all network config
  version         Int       @default(1)
  autoBackup      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([createdAt])
}

/// SystemNetworkHealth - Gateway system health metrics
model SystemNetworkHealth {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String    @unique
  hostname        String?
  kernelVersion   String?
  uptime          Int       @default(0)
  cpuUsage        Float     @default(0)
  ramTotal        Int       @default(0)
  ramUsed         Int       @default(0)
  diskTotal       Int       @default(0)
  diskUsed        Int       @default(0)
  cpuTemperature  Float?
  services        String    @default("{}") // JSON: {freeradius: {running: true, pid: 1234}, kea: {...}}
  lastUpdated     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id])
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ============================================================
// INTERFACE ALIASES - Secondary/multiple IPs per interface
// ============================================================

/// InterfaceAlias - Secondary IP addresses on an interface
model InterfaceAlias {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  interfaceId     String
  interfaceName   String    // OS interface name (eth0, br0, etc.)
  ipAddress       String    // 192.168.2.1
  netmask         String    // 255.255.255.0 or CIDR prefix
  description     String?
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  networkInterface NetworkInterface @relation(fields: [interfaceId], references: [id], onDelete: Cascade)
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, interfaceId, ipAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([interfaceId])
}

// ============================================================
// STATIC ROUTES - Default and custom routing
// ============================================================

/// StaticRoute - Persistent static routes (default + custom)
model StaticRoute {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String
  name            String
  destination     String    // 0.0.0.0/0 for default, or 10.0.0.0/24 etc
  gateway         String    // 192.168.1.1
  metric          Int       @default(100)
  interfaceName   String?   // eth0, bond0, etc.
  protocol        String    @default("static") // static, dhcp, kernel
  isDefault       Boolean   @default(false)
  enabled         Boolean   @default(true)
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([enabled])
  @@index([isDefault])
}

// ============================================================
// MULTI-WAN LOAD BALANCING
// ============================================================

/// MultiWanConfig - Multi-WAN load balancing configuration
model MultiWanConfig {
  id              String    @id @default(cuid())
  tenantId        String
  propertyId      String    @unique
  enabled         Boolean   @default(false)
  mode            String    @default("weighted") // weighted, failover, round-robin, ECMP
  healthCheckUrl  String    @default("https://1.1.1.1")
  healthCheckInterval Int   @default(10) // seconds
  healthCheckTimeout  Int   @default(3) // seconds
  failoverThreshold Int   @default(3) // consecutive failures
  autoSwitchback  Boolean   @default(true)
  switchbackDelay Int       @default(300) // seconds
  flushConnectionsOnFailover Boolean @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  wanMembers      MultiWanMember[]

  @@index([tenantId])
}

/// MultiWanMember - Individual WAN interface in multi-WAN config
model MultiWanMember {
  id              String    @id @default(cuid())
  multiWanConfigId String
  interfaceName   String    // eth0, eth1, bond0
  interfaceId     String?   // FK to NetworkInterface
  weight          Int       @default(1) // For weighted load balancing (1-100)
  gateway         String?   // Gateway IP
  healthStatus    String    @default("unknown") // online, offline, checking, unknown
  lastHealthCheck DateTime?
  enabled         Boolean   @default(true)
  isPrimary       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  multiWanConfig  MultiWanConfig @relation(fields: [multiWanConfigId], references: [id], onDelete: Cascade)

  @@unique([multiWanConfigId, interfaceName])
  @@index([multiWanConfigId])
}
