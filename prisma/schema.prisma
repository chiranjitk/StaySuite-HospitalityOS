generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// SaaS Tenant - Each hotel/hotel chain is a tenant

model AdCampaign {
  id                String         @id @default(uuid()) @db.Uuid
  tenantId          String @db.Uuid
  propertyId        String? @db.Uuid
  name              String
  description       String?
  type              String         @default("search") // search, display, metasearch, social
  platform          String         @default("google") // google, meta, tripadvisor, trivago
  status            String         @default("draft") // draft, active, paused, completed, archived
  budget            Float          @default(0)
  budgetType        String         @default("daily") // daily, lifetime
  spentAmount       Float          @default(0)
  currency          String         @default("USD")
  startDate         DateTime? @db.Timestamptz
  endDate           DateTime? @db.Timestamptz
  bidStrategy       String         @default("auto") // auto, manual, enhanced
  bidAmount         Float?
  targetCpa         Float?         // Target cost per acquisition
  targetRoas        Float?         // Target return on ad spend
  targeting         String         @default("{}") // JSON: locations, devices, audiences
  keywords          String         @default("[]") // JSON array of keywords
  negativeKeywords  String         @default("[]")
  roomTypes         String         @default("[]") // JSON array of room type IDs
  ratePlans         String         @default("[]") // JSON array of rate plan IDs
  impressions       Int            @default(0)
  clicks            Int            @default(0)
  conversions       Int            @default(0)
  revenue           Float          @default(0)
  ctr               Float          @default(0)
  cpc               Float          @default(0)
  conversionRate    Float          @default(0)
  roas              Float          @default(0)
  externalId        String? @db.Uuid        // External platform campaign ID
  externalData      String         @default("{}") // Sync data from platform
  lastSyncAt        DateTime? @db.Timestamptz
  createdAt         DateTime @db.Timestamptz       @default(now())
  updatedAt         DateTime @db.Timestamptz       @updatedAt
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  performance       AdPerformance[]

  @@index([tenantId])
  @@index([status])
  @@index([platform])
  @@index([type])
}

model AdPerformance {
  id              String    @id @default(uuid()) @db.Uuid
  campaignId      String @db.Uuid
  date            DateTime @db.Timestamptz
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  conversions     Int       @default(0)
  cost            Float     @default(0)
  revenue         Float     @default(0)
  ctr             Float     @default(0)
  cpc             Float     @default(0)
  cpa             Float     @default(0)
  roas            Float     @default(0)
  conversionRate  Float     @default(0)
  avgPosition     Float?
  qualityScore    Float?
  searchImpShare Float?
  deviceBreakdown String    @default("{}") // JSON: mobile, desktop, tablet
  sourceBreakdown String    @default("{}") // JSON: google, bing, etc.
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  campaign        AdCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
  @@index([campaignId])
  @@index([date])
}

model AISuggestion {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String @db.Uuid
  type             String
  title            String
  description      String?
  impact           String    @default("medium")
  potentialRevenue Float     @default(0)
  confidence       Float     @default(0.8)
  status           String    @default("pending")
  data             String    @default("{}")
  appliedAt        DateTime? @db.Timestamptz
  dismissedAt      DateTime? @db.Timestamptz
  createdAt        DateTime @db.Timestamptz  @default(now())
  updatedAt        DateTime @db.Timestamptz  @updatedAt
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([type])
  @@index([status])
}

model Amenity {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  name        String
  icon        String?  // Lucide icon name
  category    String   @default("general") // general, bathroom, room, view, services
  isDefault   Boolean  @default(false) // System default amenities
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @db.Timestamptz @default(now())
  updatedAt   DateTime @db.Timestamptz @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([category])
}

model Asset {
  id                      String    @id @default(uuid()) @db.Uuid
  tenantId                String @db.Uuid
  propertyId              String @db.Uuid
  name                    String
  category                String
  description             String?
  roomId                  String? @db.Uuid
  location                String?
  purchasePrice           Float?
  purchaseDate            DateTime? @db.Timestamptz
  currentValue            Float?
  warrantyExpiry          DateTime? @db.Timestamptz
  warrantyProvider        String?
  lastMaintenanceAt       DateTime? @db.Timestamptz
  nextMaintenanceAt       DateTime? @db.Timestamptz
  maintenanceIntervalDays Int?
  status                  String    @default("active")
  serialNumber            String?
  modelNumber             String?
  manufacturer            String?
  conditionScore          Int?      // 1-10 condition rating
  createdAt               DateTime @db.Timestamptz  @default(now())
  updatedAt               DateTime @db.Timestamptz  @updatedAt
  deletedAt               DateTime? @db.Timestamptz
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  property                Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  room                    Room?     @relation(fields: [roomId], references: [id])

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([category])
  @@index([status])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String @db.Uuid
  userId        String? @db.Uuid
  module        String
  action        String
  entityType    String
  entityId      String? @db.Uuid
  oldValue      String?
  newValue      String?
  ipAddress     String?
  userAgent     String?
  correlationId String? @db.Uuid
  createdAt     DateTime @db.Timestamptz @default(now())
  user          User?    @relation(fields: [userId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
}

model AutomationExecutionLog {
  id            String         @id @default(uuid()) @db.Uuid
  ruleId        String @db.Uuid
  triggerData   String?
  status        String
  errorMessage  String?
  actionsResult String?
  executedAt    DateTime @db.Timestamptz       @default(now())
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([executedAt])
}

model AutomationRule {
  id                String                   @id @default(uuid()) @db.Uuid
  tenantId          String @db.Uuid
  name              String
  description       String?
  triggerEvent      String
  triggerConditions String?
  actions           String
  isActive          Boolean                  @default(true)
  executionCount    Int                      @default(0)
  lastExecutedAt    DateTime? @db.Timestamptz
  createdAt         DateTime @db.Timestamptz                 @default(now())
  updatedAt         DateTime @db.Timestamptz                 @updatedAt
  executionLogs     AutomationExecutionLog[]
  tenant            Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([triggerEvent])
}


/// BandwidthPolicy - BW shaping policy linked to WiFi plans
model BandwidthPolicy {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  name            String
  downloadKbps    Int       @default(10240) // 10 Mbps default
  uploadKbps      Int       @default(10240)
  burstDownloadKbps Int?
  burstUploadKbps Int?
  priority        Int       @default(5) // 0=highest, 10=lowest
  planId          String? @db.Uuid   // Link to WiFiPlan
  description     String?
  enabled         Boolean   @default(true)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([planId])
  @@index([enabled])
}

model BandwidthPolicyDetail {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String @db.Uuid
  bandwidthPolicyId     String @db.Uuid
  scheduleAccessId      String? @db.Uuid
  downloadLimitBps       Int       @default(0)
  uploadLimitBps         Int       @default(0)
  guaranteedDownBps       Int       @default(0)
  guaranteedUpBps         Int       @default(0)
  burstTimeSeconds       Int       @default(0)
  burstThresholdBytes     Int       @default(0)
  burstUpTimeSeconds     Int       @default(0)
  burstUpThresholdBytes  Int       @default(0)
  contentionRatio       Int       @default(1)
  priority              Int       @default(0)
  isEnabled             Boolean   @default(true)
  createdAt             DateTime @db.Timestamptz  @default(now())
  updatedAt             DateTime @db.Timestamptz @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bandwidthPolicyId])
  @@index([scheduleAccessId])
  @@index([isEnabled])
}


/// BandwidthPool - Shared bandwidth pool per subnet
model BandwidthPool {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  name            String
  subnet          String?
  vlanId          Int?
  totalDownloadKbps Int     @default(100000) // 100 Mbps
  totalUploadKbps   Int     @default(100000)
  perUserDownloadKbps Int?
  perUserUploadKbps Int?
  enabled         Boolean   @default(true)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([vlanId])
  @@index([enabled])
}


/// BandwidthTopup - Purchasable bandwidth topup packages (Accsium tblfapbandwidthtopup)
model BandwidthTopup {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId            String @db.Uuid
  name                  String
  description           String?
  allottedUploadMb       Float     @default(0)
  allottedDownloadMb     Float     @default(0)
  allottedTotalMb        Float     @default(0)
  applicableType        String    @default("total")
  bandwidthPolicyId     String? @db.Uuid
  price                 Float     @default(0)
  currency              String    @default("USD")
  validityMinutes       Int       @default(60)
  enabled               Boolean   @default(true)
  createdAt             DateTime @db.Timestamptz  @default(now())
  updatedAt             DateTime @db.Timestamptz @updatedAt
  property              Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([enabled])
}


/// BandwidthUsageDaily - Daily aggregate bandwidth stats
model BandwidthUsageDaily {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  date            DateTime @db.Timestamptz
  totalDownloadMb Float     @default(0)
  totalUploadMb   Float     @default(0)
  uniqueUsers     Int       @default(0)
  peakUsers       Int       @default(0)
  peakTime        String?
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@index([tenantId])
  @@index([propertyId])
  @@index([date])
}


/// BandwidthUsageSession - Per-session bandwidth tracking
model BandwidthUsageSession {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  sessionId       String @db.Uuid
  username        String?
  ipAddress       String
  macAddress      String?
  planId          String? @db.Uuid
  policyId        String? @db.Uuid
  downloadBytes   Int       @default(0)
  uploadBytes     Int       @default(0)
  durationSeconds Int       @default(0)
  startedAt       DateTime @db.Timestamptz  @default(now())
  endedAt         DateTime? @db.Timestamptz
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([sessionId])
  @@index([ipAddress])
  @@index([startedAt])
  @@index([endedAt])
}

model BankAccount {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String @db.Uuid
  propertyId         String? @db.Uuid
  accountName        String
  accountNumber      String            // Masked or encrypted
  bankName           String
  bankCode           String?           // IFSC, SWIFT, Routing number, etc.
  accountType        String            @default("checking") // checking, savings, money_market
  currency           String            @default("USD")
  openingBalance     Float             @default(0)
  currentBalance     Float             @default(0)
  lastReconciledAt   DateTime? @db.Timestamptz
  lastStatementDate  DateTime? @db.Timestamptz
  status             String            @default("active") // active, closed, frozen
  isDefault          Boolean           @default(false)
  notes              String?
  createdAt          DateTime @db.Timestamptz          @default(now())
  updatedAt          DateTime @db.Timestamptz          @updatedAt
  deletedAt          DateTime? @db.Timestamptz
  transactions       BankTransaction[]
  reconciliations    Reconciliation[]
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankName])
  @@index([status])
}

model BankTransaction {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String @db.Uuid
  bankAccountId     String @db.Uuid
  transactionDate   DateTime @db.Timestamptz
  valueDate         DateTime? @db.Timestamptz         // Value date (may differ from transaction date)
  transactionType   String            // debit, credit
  amount            Float
  currency          String            @default("USD")
  balance           Float?            // Balance after transaction
  description       String?
  reference         String?           // Bank reference number
  chequeNumber      String?
  payeeName         String?
  payeeAccount      String?
  category          String?           // User-defined category
  subCategory       String?
  isReconciled      Boolean           @default(false)
  reconciledAt      DateTime? @db.Timestamptz
  importSource      String            @default("manual") // manual, csv, api, ofx
  importBatchId     String? @db.Uuid           // Batch ID for bulk imports
  rawLine           String?           // Original line from import
  notes             String?
  createdAt         DateTime @db.Timestamptz          @default(now())
  updatedAt         DateTime @db.Timestamptz          @updatedAt
  deletedAt         DateTime? @db.Timestamptz
  bankAccount       BankAccount       @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliations   Reconciliation[]
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isReconciled])
  @@index([transactionType])
  @@index([importBatchId])
}


/// BondConfig - Link aggregation / bonding configuration
model BondConfig {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  name            String    // bond0
  mode            String    @default("active-backup") // active-backup, balance-rr, balance-xor, 802.3ad, balance-tlb, balance-alb
  miimon          Int       @default(100)
  lacpRate        String    @default("slow")
  primaryMember   String?
  enabled         Boolean   @default(true)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  members         BondMember[]

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}


/// BondMember - Individual interface in a bond
model BondMember {
  id              String    @id @default(uuid()) @db.Uuid
  bondConfigId    String @db.Uuid
  interfaceId     String @db.Uuid
  priority        Int       @default(0)
  createdAt       DateTime @db.Timestamptz  @default(now())
  bondConfig      BondConfig @relation(fields: [bondConfigId], references: [id], onDelete: Cascade)
  networkInterface NetworkInterface @relation(fields: [interfaceId], references: [id], onDelete: Cascade)

  @@unique([bondConfigId, interfaceId])
  @@index([bondConfigId])
}

model Booking {
  id                  String            @id @default(uuid()) @db.Uuid
  tenantId            String @db.Uuid
  propertyId          String @db.Uuid
  confirmationCode    String            @unique
  externalRef         String?
  primaryGuestId      String @db.Uuid
  roomId              String? @db.Uuid
  roomTypeId          String @db.Uuid
  checkIn             DateTime @db.Timestamptz
  checkOut            DateTime @db.Timestamptz
  adults              Int               @default(1)
  children            Int               @default(0)
  infants             Int               @default(0)
  roomRate            Float             @default(0)
  taxes               Float             @default(0)
  fees                Float             @default(0)
  discount            Float             @default(0)
  totalAmount         Float             @default(0)
  currency            String            @default("USD")
  ratePlanId          String? @db.Uuid
  promoCode           String?
  source              String            @default("direct")
  channelId           String? @db.Uuid
  status              String            @default("draft")
  actualCheckIn       DateTime? @db.Timestamptz
  actualCheckOut      DateTime? @db.Timestamptz
  checkedInBy         String?
  checkedOutBy        String?
  cancelledAt         DateTime? @db.Timestamptz
  cancelledBy         String?
  cancellationReason  String?
  specialRequests     String?
  notes               String?
  internalNotes       String?
  groupId             String? @db.Uuid
  isGroupLeader       Boolean           @default(false)
  preArrivalSent      Boolean           @default(false)
  preArrivalCompleted Boolean           @default(false)
  preArrivalLink      String?
  preArrivalExpires   DateTime? @db.Timestamptz
  kycRequired         Boolean           @default(false)
  kycCompleted        Boolean           @default(false)
  kycStatus           String            @default("pending")
  portalToken         String?           @unique
  portalTokenExpires  DateTime? @db.Timestamptz
  eSignature          String?
  eSignedAt           DateTime? @db.Timestamptz
  preferences         String            @default("{}")
  idempotencyKey      String?           @unique
  createdAt           DateTime @db.Timestamptz          @default(now())
  updatedAt           DateTime @db.Timestamptz          @updatedAt
  deletedAt           DateTime? @db.Timestamptz
  primaryGuest        Guest             @relation(fields: [primaryGuestId], references: [id])
  roomType            RoomType          @relation(fields: [roomTypeId], references: [id])
  room                Room?             @relation(fields: [roomId], references: [id])
  property            Property          @relation(fields: [propertyId], references: [id])
  ratePlan            RatePlan?         @relation(fields: [ratePlanId], references: [id])
  group               GroupBooking?     @relation(fields: [groupId], references: [id])
  auditLogs           BookingAuditLog[]
  folios              Folio[]
  guestStays          GuestStay[]
  waitlist            WaitlistEntry?

  @@index([tenantId])
  @@index([propertyId])
  @@index([primaryGuestId])
  @@index([status])
  @@index([checkIn])
  @@index([checkOut])
  @@index([groupId])
  @@index([tenantId, propertyId, status])
  @@index([tenantId, checkIn])
  @@index([tenantId, checkOut])
}

model BookingAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  bookingId   String @db.Uuid
  action      String
  oldStatus   String?
  newStatus   String?
  notes       String?
  performedBy String?
  performedAt DateTime @db.Timestamptz @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

model Brand {
  id             String     @id @default(uuid()) @db.Uuid
  tenantId       String @db.Uuid
  name           String
  code           String     @unique
  description    String?
  logo           String?
  primaryColor   String?
  secondaryColor String?
  standards      String     @default("{}")
  status         String     @default("active")
  createdAt      DateTime @db.Timestamptz   @default(now())
  updatedAt      DateTime @db.Timestamptz   @updatedAt
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  properties     Property[]

  @@index([tenantId])
}


/// BridgeConfig - Network bridge configuration
model BridgeConfig {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  name            String    // br0, br-guest
  memberInterfaces String   @default("[]") // JSON: ["eth1","eth2"]
  stpEnabled      Boolean   @default(false)
  forwardDelay    Int       @default(15)
  helloTime       Int       @default(2)
  maxAge          Int       @default(20)
  enabled         Boolean   @default(true)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, name])
  @@index([tenantId])
  @@index([propertyId])
}

model Camera {
  id           String        @id @default(uuid()) @db.Uuid
  propertyId   String @db.Uuid
  groupId      String? @db.Uuid
  name         String
  location     String?
  streamUrl    String?
  streamType   String        @default("rtsp")
  isRecording  Boolean       @default(false)
  recordingUrl String?
  status       String        @default("online")
  posX         Int?
  posY         Int?
  createdAt    DateTime @db.Timestamptz      @default(now())
  updatedAt    DateTime @db.Timestamptz      @updatedAt
  group        CameraGroup?  @relation(fields: [groupId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  events         CameraEvent[]
  securityEvents SecurityEvent[]

  @@index([propertyId])
}

model CameraEvent {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String @db.Uuid
  cameraId       String @db.Uuid
  type           String
  timestamp      DateTime @db.Timestamptz  @default(now())
  thumbnailUrl   String?
  clipUrl        String?
  description    String?
  confidence     Float?
  isAlert        Boolean   @default(false)
  alertType      String?
  acknowledgedBy String?
  acknowledgedAt DateTime? @db.Timestamptz
  createdAt      DateTime @db.Timestamptz  @default(now())
  camera         Camera    @relation(fields: [cameraId], references: [id], onDelete: Cascade)
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cameraId])
  @@index([timestamp])
}

model CameraGroup {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String @db.Uuid
  name        String
  description String?
  createdAt   DateTime @db.Timestamptz @default(now())
  updatedAt   DateTime @db.Timestamptz @updatedAt
  cameras     Camera[]
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Campaign {
  id                String            @id @default(uuid()) @db.Uuid
  tenantId          String @db.Uuid
  name              String
  description       String?
  type              String
  subject           String?
  content           String
  templateId        String? @db.Uuid
  targetSegments    String            @default("[]")
  scheduledAt       DateTime? @db.Timestamptz
  sentAt            DateTime? @db.Timestamptz
