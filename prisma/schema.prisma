/// NatLog - NAT/connection tracking logs
model NatLog {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  timestamp       DateTime @db.Timestamptz  @default(now())
  sourceIp        String
  sourcePort      Int
  destIp          String
  destPort        Int
  protocol        String    // tcp, udp
  destDomain      String?   // Resolved domain for reporting
  action          String    @default("allow") // allow, deny
  bytes           Int       @default(0)
  sessionId       String? @db.Uuid
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([timestamp])
  @@index([sourceIp])
  @@index([destDomain])
  @@index([sessionId])
}


/// NetworkConfigBackup - Network configuration backup/restore
model NetworkConfigBackup {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  name            String
  configData      String    // Full JSON snapshot of all network config
  version         Int       @default(1)
  autoBackup      Boolean   @default(false)
  createdAt       DateTime @db.Timestamptz  @default(now())
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([createdAt])
}

