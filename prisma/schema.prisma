model Order {
  id                  String           @id @default(uuid()) @db.Uuid
  tenantId            String @db.Uuid
  propertyId          String @db.Uuid
  tableId             String? @db.Uuid
  orderNumber         String           @unique
  guestId             String? @db.Uuid
  bookingId           String? @db.Uuid
  guestName           String?
  orderType           String           @default("dine_in")
  subtotal            Float            @default(0)
  taxes               Float            @default(0)
  discount            Float            @default(0)
  totalAmount         Float            @default(0)
  currency            String           @default("USD")
  status              String           @default("pending")
  kitchenStatus       String           @default("pending")
  kitchenStartedAt    DateTime? @db.Timestamptz
  kitchenCompletedAt  DateTime? @db.Timestamptz
  folioId             String? @db.Uuid
  addToFolio          Boolean          @default(false)
  notes               String?
  specialInstructions String?
  confirmedAt         DateTime? @db.Timestamptz
  completedAt         DateTime? @db.Timestamptz
  cancelledAt         DateTime? @db.Timestamptz
  cancelledReason     String?
  createdAt           DateTime @db.Timestamptz         @default(now())
  updatedAt           DateTime @db.Timestamptz         @updatedAt
  table               RestaurantTable? @relation(fields: [tableId], references: [id])
  property            Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  items               OrderItem[]

  @@index([tenantId])
  @@index([propertyId])
  @@index([status])
}

model OrderCategory {
  id          String     @id @default(uuid()) @db.Uuid
  propertyId  String @db.Uuid
  name        String
  description String?
  imageUrl    String?
  sortOrder   Int        @default(0)
  status      String     @default("active")
  createdAt   DateTime @db.Timestamptz   @default(now())
  updatedAt   DateTime @db.Timestamptz   @updatedAt
  menuItems   MenuItem[]
  property    Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model OrderItem {
  id          String   @id @default(uuid()) @db.Uuid
  orderId     String @db.Uuid
  menuItemId  String @db.Uuid
  quantity    Int      @default(1)
  unitPrice   Float
  totalAmount Float
  notes       String?
  options     String?
  status      String   @default("pending")
  createdAt   DateTime @db.Timestamptz @default(now())
  updatedAt   DateTime @db.Timestamptz @updatedAt
  menuItem    MenuItem @relation(fields: [menuItemId], references: [id])
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ParkingSlot {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  propertyId  String? @db.Uuid
  number      String
  floor       Int       @default(1)
