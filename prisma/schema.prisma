/// Notification - In-app notifications for users
model Notification {
  id           String    @id @default(cuid())
  tenantId     String
  userId       String
  type         String    // booking, payment, housekeeping, maintenance, system, etc.
  category     String    // info, warning, success, error
  title        String
  message      String
  data         String    @default("{}") // JSON: Additional context data
  link         String?   // URL to navigate when clicked
  icon         String?   // Icon name or URL
  image        String?   // Optional image URL
  priority     String    @default("normal") // low, normal, high, urgent
  readAt       DateTime?
  dismissedAt  DateTime?
  actionType   String?   // Type of action button (view, accept, dismiss, etc.)
  actionData   String?   // JSON: Action-specific data
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@index([expiresAt])
}

/// NotificationPreference - User notification preferences per channel and category
model NotificationPreference {
  id              String   @id @default(cuid())
  tenantId        String
  userId          String
  category        String   // booking, payment, housekeeping, marketing, system, etc.
  emailEnabled    Boolean  @default(true)
  smsEnabled      Boolean  @default(true)
  pushEnabled     Boolean  @default(true)
  inAppEnabled    Boolean  @default(true)
  quietHoursStart String?  @default("22:00") // HH:mm format
  quietHoursEnd   String?  @default("08:00")
  quietHoursEnabled Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([tenantId])
  @@index([userId])
}

/// ScheduledNotification - Notifications scheduled for future delivery
model ScheduledNotification {
  id              String    @id @default(cuid())
  tenantId        String
  templateId      String?
  recipientType   String    // user, guest, staff
  recipientId     String
  recipientEmail  String?
  recipientPhone  String?
  channels        String    @default("[]") // JSON array: ["email", "sms", "push", "in_app"]
  subject         String?
  body            String
  data            String    @default("{}") // JSON: Template variables
  scheduledFor    DateTime
  status          String    @default("pending") // pending, processing, sent, failed, cancelled
  processedAt     DateTime?
  sentAt          DateTime?
  errorMessage    String?
  retryCount      Int       @default(0)
  maxRetries      Int       @default(3)
  nextRetryAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([recipientId])
  @@index([status])
  @@index([scheduledFor])
  @@index([nextRetryAt])
}

/// UserFcmToken - Firebase Cloud Messaging tokens for push notifications
