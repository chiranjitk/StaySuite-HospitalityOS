model RadCheck {
  id         String    @id @default(cuid())
  wifiUserId String?
  username   String
  attribute  String
  op         String    @default(":=")
  value      String
  priority   Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  wifiUser   WiFiUser? @relation(fields: [wifiUserId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([attribute])
}

/// RadReply - RADIUS authorization/reply attributes (FreeRADIUS SQL module)
model RadReply {
  id         String    @id @default(cuid())
  wifiUserId String?
  username   String
  attribute  String
  op         String    @default(":=")
  value      String
  priority   Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  wifiUser   WiFiUser? @relation(fields: [wifiUserId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([attribute])
}

