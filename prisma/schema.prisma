  version              String?
  radiusSecret         String
  radiusAuthPort       Int       @default(1812)
  radiusAcctPort       Int       @default(1813)
  coaEnabled           Boolean   @default(false)
  coaPort              Int       @default(3799)
  coaSecret            String?
  captivePortalEnabled Boolean   @default(false)
  captivePortalUrl     String?
  splashPageId         String? @db.Uuid
  defaultVlan          Int?
  guestVlan            Int?
  staffVlan            Int?
  managementUrl        String?
  apiUsername          String?
  apiPassword          String?
  apiPort              Int?
  status               String    @default("active")
  lastSeenAt           DateTime? @db.Timestamptz
  firmwareVersion      String?
  totalClients         Int       @default(0)
  totalSessions        Int       @default(0)
  createdAt            DateTime @db.Timestamptz  @default(now())
  updatedAt            DateTime @db.Timestamptz  @updatedAt
  property             Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant               Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, ipAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([vendor])
  @@index([status])
}

model WiFiPlan {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String @db.Uuid
  name          String
  description   String?
  downloadSpeed Int
  uploadSpeed   Int
  dataLimit     Int?
  sessionLimit  Int?
  maxDevices    Int             @default(1)
  fupPolicyId   String? @db.Uuid
  price         Float           @default(0)
  currency      String          @default("USD")
  priority      Int             @default(0)
  validityDays  Int             @default(1)
  status        String          @default("active")
  createdAt     DateTime @db.Timestamptz        @default(now())
  updatedAt     DateTime @db.Timestamptz        @updatedAt
  aaaaConfigs   WiFiAAAConfig[]
  fupPolicy     FairAccessPolicy? @relation(fields: [fupPolicyId], references: [id])
  roomTypes     RoomType[]        @relation("RoomTypeWiFiPlan")
  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions      WiFiSession[]
  wifiUsers     WiFiUser[]
  vouchers      WiFiVoucher[]

  @@index([tenantId])
}

model WiFiSession {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String @db.Uuid
  planId     String? @db.Uuid
  guestId    String? @db.Uuid
  bookingId  String? @db.Uuid
  macAddress String
  ipAddress  String?
  deviceName String?
  deviceType String?
  startTime  DateTime @db.Timestamptz  @default(now())
  endTime    DateTime? @db.Timestamptz
  dataUsed   Int       @default(0)
  duration   Int       @default(0)
  authMethod String    @default("voucher")
  status     String    @default("active")
  createdAt  DateTime @db.Timestamptz  @default(now())
  updatedAt  DateTime @db.Timestamptz  @updatedAt
  plan       WiFiPlan? @relation(fields: [planId], references: [id])
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([macAddress])
  @@index([guestId])
}

model WiFiUser {
  id               String     @id @default(uuid()) @db.Uuid
  tenantId         String @db.Uuid
  propertyId       String @db.Uuid
  username         String     @unique
  password         String
  guestId          String? @db.Uuid
  bookingId        String? @db.Uuid
  userType         String     @default("guest")
  planId           String? @db.Uuid
  validFrom        DateTime @db.Timestamptz
  validUntil       DateTime @db.Timestamptz
  maxSessions      Int        @default(1)
  sessionCount     Int        @default(0)
  totalBytesIn     Int        @default(0)
  totalBytesOut    Int        @default(0)
  status           String     @default("active")
  radiusSynced     Boolean    @default(false)
  radiusSyncedAt   DateTime? @db.Timestamptz
  lastAccountingAt DateTime? @db.Timestamptz
  createdAt        DateTime @db.Timestamptz   @default(now())
  updatedAt        DateTime @db.Timestamptz   @updatedAt
  radCheck         RadCheck[]
  radReply         RadReply[]
  plan             WiFiPlan?  @relation(fields: [planId], references: [id])
  property         Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([username])
  @@index([guestId])
  @@index([bookingId])
  @@index([status])
}


/// WiFiUserStatusHistory - User status change audit trail (Accsium tbluserstatushistory)
model WiFiUserStatusHistory {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  username        String
  userId          String? @db.Uuid
  oldStatus       String?
  newStatus       String
  changedBy       String?
  changeReason    String?
  ipAddress       String?
  createdAt       DateTime @db.Timestamptz @default(now())
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([username])
  @@index([userId])
  @@index([createdAt])
}

model WiFiVoucher {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String @db.Uuid
  planId     String @db.Uuid
  code       String    @unique
  guestId    String? @db.Uuid
  bookingId  String? @db.Uuid
  isUsed     Boolean   @default(false)
  usedAt     DateTime? @db.Timestamptz
  validFrom  DateTime @db.Timestamptz
  validUntil DateTime @db.Timestamptz
  status     String    @default("active")
  notes      String?
  issuedTo   String?
  issuedAt   DateTime? @db.Timestamptz
  createdAt  DateTime @db.Timestamptz  @default(now())
  updatedAt  DateTime @db.Timestamptz  @updatedAt
  plan       WiFiPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([code])
}

model WorkOrder {
  id               String        @id @default(uuid()) @db.Uuid
  tenantId         String @db.Uuid
  propertyId       String @db.Uuid
  vendorId         String? @db.Uuid
  roomId           String? @db.Uuid
  assetId          String? @db.Uuid
  workOrderNumber  String        @unique
  title            String
  description      String?
  type             String        @default("general") // general, plumbing, electrical, hvac, carpentry, painting, cleaning, other
  priority         String        @default("medium") // low, medium, high, urgent
  status           String        @default("pending") // pending, assigned, in_progress, completed, cancelled, on_hold
  requestedBy      String?
  assignedAt       DateTime? @db.Timestamptz
  scheduledDate    DateTime? @db.Timestamptz
  startedAt        DateTime? @db.Timestamptz
  completedAt      DateTime? @db.Timestamptz
  estimatedCost    Float?
  actualCost       Float?
  estimatedHours   Float?
  actualHours      Float?
  notes            String?
  completionNotes  String?
  attachments      String        @default("[]") // JSON array of attachment URLs
  vendorNotes      String?       // Notes from vendor
  rating           Int?          // Guest/staff rating 1-5
  feedback         String?       // Feedback on work quality
  createdAt        DateTime @db.Timestamptz      @default(now())
  updatedAt        DateTime @db.Timestamptz      @updatedAt
  deletedAt        DateTime? @db.Timestamptz
  vendor           Vendor?       @relation(fields: [vendorId], references: [id])
  room             Room?         @relation(fields: [roomId], references: [id])
  property         Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  payments         VendorPayment[]
  tenant           Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([vendorId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([scheduledDate])
}


