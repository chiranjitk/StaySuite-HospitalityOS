/// LiveSession - Real-time active session tracking (Accsium tblliveuser equivalent)
/// O(1) session lookup by username/IP — replaces slow radacct file parsing
model LiveSession {
  id                  String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId          String @db.Uuid
  acctSessionId       String @db.Uuid  @unique
  username            String    @unique
  userId              String? @db.Uuid
  planId              String? @db.Uuid
  nasIpAddress        String
  nasIdentifier       String?
  nasPortType         String?
  framedIpAddress      String    @default("")
  macAddress          String    @default("")
  clientIpAddress      String    @default("")
  deviceType          String?
  operatingSystem     String?
  manufacturer        String?
  bandwidthPolicyId    String? @db.Uuid
  bandwidthDown       Int       @default(0)
  bandwidthUp         Int       @default(0)
  maxInputOctets      Int       @default(0)
  maxOutputOctets     Int       @default(0)
  maxTotalOctets      Int       @default(0)
  sessionTimeout      Int       @default(0)
  idleTimeout         Int       @default(0)
  lastInterimUpdate    DateTime? @db.Timestamptz
  currentInputBytes    Int       @default(0)
  currentOutputBytes   Int       @default(0)
  currentSessionTime   Int       @default(0)
  status              String    @default("active")
  roomNo              String?
  hotelId             String? @db.Uuid
  urlFilterPolicy      String?
  authMethod          String?
  startedAt           DateTime @db.Timestamptz @default(now())
  updatedAt           DateTime @db.Timestamptz @updatedAt
  property            Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([tenantId])
  @@index([username])
  @@index([nasIpAddress])
  @@index([status])
  @@index([userId])
  @@index([framedIpAddress])
  @@index([macAddress])
}

model LoyaltyPointTransaction {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String @db.Uuid
  guestId        String @db.Uuid
  points         Int      // positive for earn, negative for redeem
  balance        Int      // balance after transaction
  type           String   // earn, redeem, expire, adjust, bonus, referral
  source         String?  // booking, promotion, manual, etc.
  referenceId    String? @db.Uuid  // related entity id (booking, redemption, etc.)
  referenceType  String?  // booking, redemption, etc.
  description    String?
  expiresAt      DateTime? @db.Timestamptz // for points that expire
  createdAt      DateTime @db.Timestamptz @default(now())
  guest          Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([type])
  @@index([expiresAt])
}

model LoyaltyRedemption {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  guestId         String @db.Uuid
  rewardId        String @db.Uuid
  pointsSpent     Int
  status          String   @default("completed") // pending, completed, cancelled, expired
  redemptionCode  String?  @unique // code to claim the reward
  redeemedAt      DateTime @db.Timestamptz @default(now())
  expiresAt       DateTime? @db.Timestamptz
  cancelledAt     DateTime? @db.Timestamptz
  cancelledReason String?
  notes           String?
  createdAt       DateTime @db.Timestamptz @default(now())
  updatedAt       DateTime @db.Timestamptz @updatedAt
  guest           Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reward          LoyaltyReward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([guestId])
  @@index([rewardId])
  @@index([status])
  @@index([redemptionCode])
}

model LoyaltyReward {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String @db.Uuid
  name               String
  description        String?
  category           String   @default("general") // general, room, dining, spa, experience
  pointsCost         Int
  monetaryValue      Float    @default(0) // equivalent monetary value for reporting
  currency           String   @default("USD")
  imageUrl           String?
  isAvailable        Boolean  @default(true)
  availableFrom      DateTime? @db.Timestamptz
  availableUntil     DateTime? @db.Timestamptz
  maxRedemptions     Int?     // null means unlimited
  currentRedemptions Int      @default(0)
  minTierRequired    String?  // minimum tier name required to redeem
  termsConditions    String?
  sortOrder          Int      @default(0)
  createdAt          DateTime @db.Timestamptz @default(now())
  updatedAt          DateTime @db.Timestamptz @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  redemptions        LoyaltyRedemption[]

  @@index([tenantId])
  @@index([category])
  @@index([isAvailable])
}

model LoyaltyTier {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String @db.Uuid
  name             String   // bronze, silver, gold, platinum
  displayName      String   // Bronze Member, Silver Elite, etc.
  minPoints        Int      @default(0)
  maxPoints        Int?     // null means no upper limit
  pointsMultiplier Float    @default(1.0) // earn rate multiplier
  benefits         String   @default("[]") // JSON array of benefit strings
  color            String   @default("#cd7f32") // tier color for UI
  icon             String?  // optional icon name
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  createdAt        DateTime @db.Timestamptz @default(now())
  updatedAt        DateTime @db.Timestamptz @updatedAt
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([minPoints])
}

model LoyaltyTransaction {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String @db.Uuid
  guestId       String @db.Uuid
  points        Int
  type          String
  reason        String
  referenceType String?
  referenceId   String? @db.Uuid
  balanceAfter  Int
  createdAt     DateTime @db.Timestamptz @default(now())

  @@index([tenantId])
  @@index([guestId])
}


/// MacFilter - MAC address whitelist/blacklist
model MacFilter {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  macAddress      String
  action          String    @default("allow") // allow, deny
  listType        String    @default("blacklist") // whitelist, blacklist
  description     String?
  linkedType      String?   // guest, staff, device
  linkedId        String? @db.Uuid
  expiresAt       DateTime? @db.Timestamptz
  enabled         Boolean   @default(true)
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, macAddress])
  @@index([tenantId])
  @@index([propertyId])
  @@index([listType])
  @@index([enabled])
}


/// MaintenanceBlock - Room out-of-order / out-of-service scheduling
model MaintenanceBlock {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  roomId          String @db.Uuid
  roomNumber      String
  reason          String                          // maintenance, renovation, deep_cleaning, inspection, quarantine
  description     String?
  startDate       DateTime @db.Timestamptz
  endDate         DateTime? @db.Timestamptz
  blockedBy       String?                         // user who created the block
  status          String   @default("scheduled")  // scheduled, active, completed, cancelled
  priority        String   @default("normal")     // normal, high, urgent
  vendorId        String? @db.Uuid
  estimatedCost   Float?
  actualCost      Float?
  notes           String?
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  room            Room      @relation(fields: [roomId], references: [id])
  property        Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

model ManualTransaction {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String @db.Uuid
  paymentId   String @db.Uuid
  amount      Float
  currency    String
  status      String   @default("completed") // completed, refunded, partially_refunded, failed
  refundAmount Float   @default(0)
  refundId    String? @db.Uuid
  metadata    String   @default("{}") // JSON string for additional data
  createdAt   DateTime @db.Timestamptz @default(now())
  updatedAt   DateTime @db.Timestamptz @updatedAt

  @@index([tenantId])
  @@index([paymentId])
  @@index([status])
}

model MenuItem {
  id              String        @id @default(uuid()) @db.Uuid
  propertyId      String @db.Uuid
  categoryId      String @db.Uuid
  name            String
  description     String?
  imageUrl        String?
  price           Float
  currency        String        @default("USD")
  options         String        @default("[]")
  isVegetarian    Boolean       @default(false)
  isVegan         Boolean       @default(false)
  isGlutenFree    Boolean       @default(false)
  allergens       String        @default("[]")
  isAvailable     Boolean       @default(true)
  availableTimes  String?
  preparationTime Int?
  kitchenStation  String?
  sortOrder       Int           @default(0)
  status          String        @default("active")
  createdAt       DateTime @db.Timestamptz      @default(now())
  updatedAt       DateTime @db.Timestamptz      @updatedAt
  deletedAt       DateTime? @db.Timestamptz
  category        OrderCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  property        Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  orderItems      OrderItem[]

  @@index([propertyId])
  @@index([categoryId])
}

model MessageTemplate {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String @db.Uuid
  name               String
  category           String
  channel            String
  subject            String?
  body               String
  variables          String   @default("[]")
  isQuickReply       Boolean  @default(false)
  shortcut           String?
  whatsappTemplateId String? @db.Uuid
  whatsappCategory   String?
  isActive           Boolean  @default(true)
  usageCount         Int      @default(0)
  createdAt          DateTime @db.Timestamptz @default(now())
  updatedAt          DateTime @db.Timestamptz @updatedAt
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, name, channel])
  @@index([tenantId])
  @@index([channel])
  @@index([category])
}

model MetasearchConnection {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String @db.Uuid
  propertyId      String @db.Uuid
  platform        String    // trivago, tripadvisor, kayak, skyscanner
  externalId      String? @db.Uuid
  status          String    @default("pending")
  connectionUrl   String?
  feedFormat      String    @default("xml")
  lastSyncAt      DateTime? @db.Timestamptz
  lastError       String?
  lastErrorAt     DateTime? @db.Timestamptz
  impressions     Int       @default(0)
  clicks          Int       @default(0)
  bookings        Int       @default(0)
  revenue         Float     @default(0)
  cost            Float     @default(0)
  ctr             Float     @default(0)
  config          String    @default("{}")
  createdAt       DateTime @db.Timestamptz  @default(now())
  updatedAt       DateTime @db.Timestamptz  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, propertyId, platform])
  @@index([tenantId])
  @@index([platform])
  @@index([status])
}

