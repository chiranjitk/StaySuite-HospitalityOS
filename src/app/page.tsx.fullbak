      case 'ai-provider':
      case 'ai-settings':
        return <WrappedSection component={aiAdminSections.AIProviderSettings} />;
      case 'ai-insights':
        return <WrappedSection component={aiAdminSections.AIInsights} />;

      // --- Admin ---
      case 'admin-tenants':
        return <WrappedSection component={aiAdminSections.TenantManagement} />;
      case 'admin-tenant-lifecycle':
      case 'admin-lifecycle':
        return <WrappedSection component={aiAdminSections.TenantLifecycle} />;
      case 'admin-users':
