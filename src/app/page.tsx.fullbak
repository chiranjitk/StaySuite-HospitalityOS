      case 'notifications-logs':
        return <WrappedSection component={integrationsNotificationsSections.DeliveryLogs} />;
      case 'notifications-settings':
        return <WrappedSection component={integrationsNotificationsSections.NotificationSettingsComponent} />;

      // --- Webhooks ---
      case 'webhooks-events':
