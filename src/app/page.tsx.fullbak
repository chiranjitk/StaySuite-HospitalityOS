      case 'integrations-wifi':
        return <WrappedSection component={integrationsNotificationsSections.WifiGateways} />;
      case 'integrations-pos':
        return <WrappedSection component={integrationsNotificationsSections.PosSystems} />;
      case 'integrations-apis':
        return <WrappedSection component={integrationsNotificationsSections.ThirdPartyApis} />;

      // --- Notifications ---
