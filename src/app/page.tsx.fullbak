      case 'marketing-promotions':
        return <WrappedSection component={crmAutomationSections.Campaigns} />;
      case 'marketing-booking-engine':
        return <WrappedSection component={chainMarketingEventsSections.DirectBookingEngine} />;

      // --- Events ---
      case 'events-spaces':
        return <WrappedSection component={chainMarketingEventsSections.EventSpaces} />;
      case 'events-calendar':
        return <WrappedSection component={chainMarketingEventsSections.EventCalendar} />;
      case 'events-booking':
        return <WrappedSection component={chainMarketingEventsSections.EventBooking} />;
      case 'events-resources':
        return <WrappedSection component={chainMarketingEventsSections.EventResources} />;

      // --- IoT ---
      case 'iot-devices':
        return <WrappedSection component={iotStaffHelpAdsSections.DeviceManagement} />;
      case 'iot-controls':
        return <WrappedSection component={iotStaffHelpAdsSections.RoomControls} />;
      case 'iot-energy':
        return <WrappedSection component={iotStaffHelpAdsSections.EnergyDashboard} />;

      // --- Staff Management ---
      case 'staff-shifts':
        return <WrappedSection component={iotStaffHelpAdsSections.ShiftScheduling} />;
      case 'staff-attendance':
        return <WrappedSection component={iotStaffHelpAdsSections.AttendanceTracking} />;
      case 'staff-tasks':
        return <WrappedSection component={iotStaffHelpAdsSections.TaskAssignment} />;
      case 'staff-communication':
        return <WrappedSection component={iotStaffHelpAdsSections.InternalCommunication} />;
      case 'staff-performance':
        return <WrappedSection component={reportsRevenueSections.StaffPerformance} />;
      case 'staff-skills':
        return <WrappedSection component={iotStaffHelpAdsSections.SkillsManagement} />;

      // --- Help Center ---
      case 'help-center':
      case 'help-articles':
        return selectedArticleId ? (
          <iotStaffHelpAdsSections.ArticleViewer
            articleId={selectedArticleId}
            onBack={() => setSelectedArticleId(null)}
          />
        ) : (
          <iotStaffHelpAdsSections.HelpCenter onSelectArticle={(id: string) => setSelectedArticleId(id)} />
        );
      case 'help-tutorials':
        return (
          <div className="space-y-4">
            <iotStaffHelpAdsSections.HelpCenter onSelectArticle={(id: string) => setSelectedArticleId(id)} />
          </div>
        );

      // --- User Profile ---
      case 'profile':
      case 'profile-user':
        return <WrappedSection component={iotStaffHelpAdsSections.UserProfile} />;

      // --- UI Showcase ---
      case 'ui-showcase':
        return <iotStaffHelpAdsSections.UIStyleShowcase />;

      // --- Ads ---
      case 'ads-campaigns':
        return <WrappedSection component={iotStaffHelpAdsSections.AdCampaigns} />;
      case 'ads-google':
        return <WrappedSection component={iotStaffHelpAdsSections.GoogleHotelAds} />;
      case 'ads-performance':
        return <WrappedSection component={iotStaffHelpAdsSections.PerformanceTracking} />;
      case 'ads-roi':
        return <WrappedSection component={iotStaffHelpAdsSections.ROIAnalytics} />;

      // --- Feature Not Found ---
      default:
        return (
          <div className="flex flex-col items-center justify-center min-h-[60vh] text-center">
            <div className="rounded-full bg-muted p-6 mb-4">
              <svg
                className="h-12 w-12 text-muted-foreground"
                fill="none"
                height="24"
                stroke="currentColor"
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth="2"
                viewBox="0 0 24 24"
                width="24"
              >
                <path d="M12 2L2 7l10 5 10-5-10-5z" />
                <path d="M2 17l10 5 10-5" />
                <path d="M2 12l10 5 10-5" />
              </svg>
            </div>
            <h2 className="text-2xl font-semibold mb-2">Feature Not Found</h2>
            <p className="text-muted-foreground max-w-md">
              The <span className="font-medium">{activeSection.replace(/-/g, ' ')}</span> module is not available or has been moved.
              Please contact your administrator for assistance.
            </p>
          </div>
        );
    }
  };

  return (
    <AppLayout>
      <Suspense fallback={<SectionLoader />}>
        {renderContent()}
      </Suspense>
    </AppLayout>
  );
}
